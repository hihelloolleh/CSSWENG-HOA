     VEHICLES VIEW — STUB
     Layout: views/layouts/main.ejs (has sidebar)
     Controller: controllers/vehicleController.js
     TODO (SPRINT 2+): BUILD THIS PAGE (table, register/edit/delete)
     ============================================================ -->

<div class="main-wrapper"> 
    <div class="sidebar-open nav-item"> 
        <i class="fa-solid fa-bars"></i>
        <span>Open Sidebar</span>
    </div>
    <header class="topbar">
        <div class="topbar-left">
            <h1 class="page-title">Vehicles</h1>
            <p class="page-subtitle">Manage registered vehicles</p>
        </div>
        <div class="topbar-right">
            <div class="topbar-user">
                <div class="user-avatar"><i class="fa-solid fa-user"></i></div>
                <div class="user-info">
                    <span class="user-name">Village Admin</span>
                    <span class="user-role">Administrator</span>
                </div>
            </div>
        </div>
    </header>

    <main class="content">
        <div class="action-buttons">
            <button class="btn btn-primary" onclick="document.getElementById('vehicleModal').classList.add('active')">
                <i class="fa-solid fa-plus"></i> Add Vehicle
            </button>
            <button class="btn btn-secondary">
                <i class="fa-solid fa-upload"></i> Upload Excel
            </button>
        </div>

        <!-- SEARCH -->
        <div class="search-bar" style="margin-bottom: 12px;">
            <input type="text" class="search-input" id="searchInput"
                   placeholder="Search by plate, owner, type, or color...">
        </div>
        
        <!-- VEHICLE COUNTER -->
        <p class="vehicle-count" id="paymentCount">
            Showing <strong><%= vehicles.length %></strong> vehicles
        </p>
 
 
        

        <div class="table-container">
            <table class="data-table">
                <thead>
                    <tr>
                        <th>Plate Number</th>
                        <th>Type</th>
                        <th>Make & Model</th>
                        <th>Color</th>
                        <th>Sticker Year</th>
                        <th>Owner/s</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (vehicles.length === 0) { %>
                        <tr><td colspan="7" class="empty-state">No vehicles registered yet.</td></tr>
                    <% } else { %>
                        <% vehicles.forEach(function(vehicle) { %>
                            <tr>
                                <td><span class="plate-number"><%= vehicle.plate_number || 'N/A' %></span></td>
                                <td><%= vehicle.type %></td>
                                <td><%= vehicle.make %> <%= vehicle.model %></td>
                                <td><%= vehicle.color %></td>
                                
                                <td>
                                    <% if (!vehicle.sticker_year) { %>
                                        <span class="sticker-badge sticker-none">None</span>
                                    <% } else if (vehicle.sticker_year >= 2026) { %>
                                        <span class="sticker-badge sticker-valid"><%= vehicle.sticker_year %></span>
                                    <% } else { %>
                                        <span class="sticker-badge sticker-expired"><%= vehicle.sticker_year %></span>
                                    <% } %>
                                </td>
                                
                                <td><%= vehicle.homeowners || 'Unassigned' %></td>
                                <td style="display: flex; gap: 10px;">
                                    <button type="button" class="btn-icon" onclick="openEditModal('<%= vehicle.vehicle_id %>', '<%= vehicle.type %>', '<%= vehicle.plate_number %>', '<%= vehicle.make %>', '<%= vehicle.model %>', '<%= vehicle.color %>', '<%= vehicle.sticker_year %>', '<%= vehicle.resident_ids || "" %>')">
                                        <i class="fa-solid fa-edit"></i>
                                    </button>

                                    <button class="btn-icon btn-icon-danger"
                                            onclick="confirmDelete(this.dataset.id, this.dataset.label)"
                                            data-id="<%= vehicle.vehicle_id %>"
                                            data-label="<%= vehicle.plate_number || vehicle.make + ' ' + vehicle.model %>">
                                        <i class="fa-solid fa-trash"></i>
                                    </button>
                                </td>
                            </tr>
                        <% }) %>
                    <% } %>
                </tbody>
            </table>
        </div>
    </main>

    <div id="vehicleModal" class="modal">
        <div class="modal-content">
            <div class="modal-header">
                <h2>Add New Vehicle</h2>
                <button class="modal-close" onclick="document.getElementById('vehicleModal').classList.remove('active')">&times;</button>
            </div>
            <div class="modal-body">
                <form id="vehicleForm" action="/vehicles/register" method="POST">
                    
                    <div class="form-group">
                        <label>Vehicle Type</label>
                        <select id="edit_type" name="type" class="form-control" style="width: 100%; padding: 8px;" required>
                            <option value="">Select Vehicle Type</option>
                            <option value="Car">Car</option>
                            <option value="Motorcycle">Motorcycle</option>
                            <option value="E-Bike">E-Bike</option>
                            <option value="Others">Others</option>
                        </select>
                    </div>

                    <div class="form-group">
                        <label>Plate Number</label>
                        <input type="text" name="plate_number" required placeholder="ABC 1234">
                    </div>

                    <div class="form-row">
                        <div class="form-group">
                            <label>Make</label>
                            <input type="text" name="make" placeholder="e.g., Toyota" required>
                        </div>

                        <div class="form-group">
                            <label>Model</label>
                            <input type="text" name="model" placeholder="e.g., Vios" required>
                        </div>
                    </div>

                    <div class="form-row">
                        <div class="form-group">
                            <label>Color</label>
                            <input type="text" name="color" required>
                        </div>

                        <div class="form-group">
                            <label>Sticker Year</label>
                            <input type="number" name="sticker_year" placeholder="2026" required>
                        </div>
                    </div>

                    <div class="form-group" style="margin-top: 15px;">
                        <label>Owners</label>
                        <div style="display: flex; gap: 10px; margin-bottom: 10px;">
                            <!-- TODO: IMPLEMENT SEARCH DROPDOWN
                                   goto views/property.ejs and search "Resident search dropdown"
                                   for reference -->
                            <select id="add_resident_select" class="form-control" style="flex: 1; padding: 8px;">
                                <option value="">Select Resident to Add as Vehicle Owner</option>
                                <% if (locals.residents) { %>
                                    <% residents.forEach(resident => { %>
                                        <option value="<%= resident.resident_id %>"><%= resident.full_name %></option>
                                    <% }); %>
                                <% } %>
                            </select>
                            <button type="button" class="btn btn-secondary" onclick="addResidentToForm('add')">Add</button>
                        </div>
                        
                        <div id="add_resident_tags" style="display: flex; flex-wrap: wrap; gap: 8px; min-height: 44px; padding: 10px; border: 1px dashed #ccc; border-radius: 4px;"></div>
                        
                        <div id="add_hidden_inputs"></div>
                    </div>
                    
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" onclick="document.getElementById('vehicleModal').classList.remove('active')">Cancel</button>
                        <button type="submit" class="btn btn-primary">Save Vehicle</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<div id="editVehicleModal" class="modal">
    <div class="modal-content">
        <div class="modal-header">
            <h2>Edit Vehicle Details</h2>
            <button class="modal-close" onclick="document.getElementById('editVehicleModal').classList.remove('active')">&times;</button>
        </div>
        <div class="modal-body">
            <form id="editVehicleForm" method="POST">
                <div class="form-group">
                    <label>Plate Number</label>
                    <input type="text" id="edit_plate_number" name="plate_number" required>
                </div>

                <div class="form-group" style="margin-top: 15px;">
                    <label>Vehicle Type</label>
                    <select id="edit_type" name="type" class="form-control" style="width: 100%; padding: 8px;" required>
                        <option value="">Select Vehicle Type</option>
                        <option value="Car">Car</option>
                        <option value="Motorcycle">Motorcycle</option>
                        <option value="E-Bike">E-Bike</option>
                        <option value="Others">Others</option>
                    </select>
                </div>

                <div class="form-group" style="margin-top: 15px;">
                    <label>Owners</label>
                    <div style="display: flex; gap: 10px; margin-bottom: 10px;">
                        <!-- TODO: IMPLEMENT SEARCH DROPDOWN
                                   goto views/property.ejs and search "Resident search dropdown"
                                   for reference -->
                        <select id="edit_resident_select" class="form-control" style="flex: 1; padding: 8px;">
                            <option value="">Select Resident to Add as Vehicle Owner</option>
                            <% if (locals.residents) { %>
                                <% residents.forEach(resident => { %>
                                    <option value="<%= resident.resident_id %>"><%= resident.full_name %></option>
                                <% }); %>
                            <% } %>
                        </select>
                        <button type="button" class="btn btn-secondary" onclick="addResidentToForm('edit')">Add</button>
                    </div>
                    
                    <div id="edit_resident_tags" style="display: flex; flex-wrap: wrap; gap: 8px; min-height: 44px; padding: 10px; border: 1px dashed #ccc; border-radius: 4px;"></div>
                    
                    <div id="edit_hidden_inputs"></div>
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label>Make</label>
                        <input type="text" id="edit_make" name="make" required>
                    </div>
                    <div class="form-group">
                        <label>Model</label>
                        <input type="text" id="edit_model" name="model" required>
                    </div>
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label>Color</label>
                        <input type="text" id="edit_color" name="color" required>
                    </div>

                    <div class="form-group">
                        <label>Sticker Year</label>
                        <input type="number" id="edit_sticker_year" name="sticker_year">
                    </div>
                </div>
                
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" onclick="document.getElementById('editVehicleModal').classList.remove('active')">Cancel</button>
                    <button type="submit" class="btn btn-primary">Update Vehicle</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- ── DELETE MODAL ─────────────────────────────────────────────────────────── -->
<div id="deleteVehicleModal" class="modal">
    <div class="modal-content" style="max-width:450px;">
        <div class="modal-header">
            <h2>Delete Vehicle</h2>
            <button class="modal-close" onclick="document.getElementById('deleteVehicleModal').classList.remove('active')">&times;</button>
        </div>
        <div class="modal-body">
            <p>Are you sure you want to delete <strong id="deleteVehicleName"></strong>?</p>
            <p style="color:#dc3545;font-size:13px;margin-top:8px;font-weight:500;">This action cannot be undone.</p>
        </div>
        <div class="modal-footer">
            <button type="button" class="btn btn-secondary" onclick="document.getElementById('deleteVehicleModal').classList.remove('active')">Cancel</button>
            <form id="deleteVehicleForm" method="POST" style="margin:0;">
                <button type="submit" class="btn btn-danger">Delete</button>
            </form>
        </div>
    </div>
</div>

<script>
    function confirmDelete(id, label) {
        document.getElementById('deleteVehicleName').textContent = label;
        document.getElementById('deleteVehicleForm').action = '/vehicles/delete/' + id;
        document.getElementById('deleteVehicleModal').classList.add('active');
    }

    window.onclick = function(event) {
        const m = document.getElementById('deleteVehicleModal');
        if (event.target === m) m.classList.remove('active');
    };

    function addResidentToForm(mode){
        const selectBox = document.getElementById(`${mode}_resident_select`);
        const id = selectBox.value;
        const name = selectBox.options[selectBox.selectedIndex]?.text;

        if (!id) return;

        const tagsContainer = document.getElementById(`${mode}_resident_tags`);
        const hiddenContainer = document.getElementById(`${mode}_hidden_inputs`);

        if (document.getElementById(`${mode}_hidden_${id}`)){
            alert('This resident has already been added.');
            return;
        }

        const tag = document.createElement('div');

        tag.id = `${mode}_tag_${id}`;
        tag.style.cssText = "background: #e0f7fa; color: #006064; padding: 4px 10px; border-radius: 15px; display: flex; align-items: center; gap: 8px; font-size: 14px;";
        tag.innerHTML = `
            ${name} 
            <button type="button" style="border: none; background: transparent; color: red; cursor: pointer; font-weight: bold;" onclick="removeResidentFromForm('${mode}', '${id}')">&times;</button>
        `;
        tagsContainer.appendChild(tag);

        const hiddenInput = document.createElement('input');
        hiddenInput.type = "hidden";
        hiddenInput.name = "resident_ids";
        hiddenInput.value = id;
        hiddenInput.id = `${mode}_hidden_${id}`;
        hiddenContainer.appendChild(hiddenInput);
        
        selectBox.value = ''; 
    }

    function removeResidentFromForm(mode, id){
        document.getElementById(`${mode}_tag_${id}`).remove();
        document.getElementById(`${mode}_hidden_${id}`).remove();
    }

    function openEditModal(id, type, plate_number, make, model, color, sticker_year, resident_ids_string){
        
        document.getElementById('editVehicleForm').action = '/vehicles/update/' + id;
        
        document.getElementById('edit_type').value = type || '';
        document.getElementById('edit_plate_number').value = plate_number || '';
        document.getElementById('edit_make').value = make || '';
        document.getElementById('edit_model').value = model || '';
        document.getElementById('edit_color').value = color || '';
        document.getElementById('edit_sticker_year').value = sticker_year || '';
        
        document.getElementById('edit_resident_tags').innerHTML = '';
        document.getElementById('edit_hidden_inputs').innerHTML = '';
        
        if(resident_ids_string){
            const selectedIds = resident_ids_string.split(',');
            const selectBox = document.getElementById('edit_resident_select');
            
            selectedIds.forEach(ownerId => {
                const optionExists = selectBox.querySelector(`option[value="${ownerId}"]`);
                if(optionExists){
                    selectBox.value = ownerId;
                    addResidentToForm('edit');
                }
            });
        }
        
        document.getElementById('editVehicleModal').classList.add('active');
    }
</script>

<script> // search functionality

    document.addEventListener('DOMContentLoaded', () =>{
        const searchInput = document.getElementById('searchInput');
        const vehicleCountDisplay = document.getElementById('vehicleCount');
        const tableBody = document.querySelector('.data-table tbody');
        
        const rows = tableBody.querySelectorAll('tr:not(:has(.empty-state))'); 

        if(searchInput && rows.length > 0){
            searchInput.addEventListener('input', function(){
                const searchTerm = this.value.toLowerCase().trim();
                let visibleCount = 0;

                rows.forEach(row =>{
                    const rowText = row.textContent.toLowerCase();
                    
                    if (rowText.includes(searchTerm)){
                        row.style.display = ''; 
                        visibleCount++;
                    }
                    else{
                        row.style.display = 'none'; 
                    }
                });

                vehicleCountDisplay.textContent = visibleCount;
            });
        }
    });
</script>

<script src="/js/sidebar.js"></script>
