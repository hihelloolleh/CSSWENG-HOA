     ============================================================ -->

<div class="main-wrapper"> 
    <div class="sidebar-open nav-item"> 
        <i class="fa-solid fa-bars"></i>
        <span>Open Sidebar</span>
    </div>
    <header class="topbar">
        <div class="topbar-left">
            <h1 class="page-title">Vehicles</h1>
            <p class="page-subtitle">Manage registered vehicles</p>
        </div>
        <div class="topbar-right">
            <div class="topbar-user">
                <div class="user-avatar"><i class="fa-solid fa-user"></i></div>
                <div class="user-info">
                    <span class="user-name">Village Admin</span>
                    <span class="user-role">Administrator</span>
                </div>
            </div>
        </div>
    </header>

    <main class="content">
        <div class="action-buttons">
            <button class="btn btn-primary" onclick="document.getElementById('vehicleModal').classList.add('active')">
                <i class="fa-solid fa-plus"></i> Add Vehicle
            </button>
            <button class="btn btn-secondary">
                <i class="fa-solid fa-upload"></i> Upload Excel
            </button>
        </div>

        <div class="search-section" style="margin: 20px 0;">
            <input type="text" id="searchInput" class="form-control" placeholder="Search by plate, owner, type, or color..." style="width: 100%; max-width: 400px; padding: 10px; margin-bottom: 10px;">
            
            <div class="counter-text" style="font-weight: 600; color: #555;">
                Total Vehicles: <span id="vehicleCount"><%= vehicles.length %></span>
            </div>
        </div>

        <div class="table-container">
            <table class="data-table">
                <thead>
                    <tr>
                        <th>Plate Number</th>
                        <th>Type</th>
                        <th>Make & Model</th>
                        <th>Color</th>
                        <th>Sticker Year</th>
                        <th>Owner/s</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (vehicles.length === 0) { %>
                        <tr><td colspan="7" class="empty-state">No vehicles registered yet.</td></tr>
                    <% } else { %>
                        <% vehicles.forEach(function(vehicle) { %>
                            <tr>
                                <td><span class="plate-number"><%= vehicle.plate_number %></span></td>
                                <td><%= vehicle.type %></td>
                                <td><%= vehicle.make %> <%= vehicle.model %></td>
                                <td><%= vehicle.color %></td>
                                
                                <td>
                                    <% if (!vehicle.sticker_year) { %>
                                        <span class="sticker-badge sticker-none">None</span>
                                    <% } else if (vehicle.sticker_year >= 2026) { %>
                                        <span class="sticker-badge sticker-valid"><%= vehicle.sticker_year %></span>
                                    <% } else { %>
                                        <span class="sticker-badge sticker-expired"><%= vehicle.sticker_year %></span>
                                    <% } %>
                                </td>
                                
                                <td><%= vehicle.homeowners || 'Unassigned' %></td>
                                <td style="display: flex; gap: 10px;">
                                    <button type="button" class="btn-icon" onclick="openEditModal('<%= vehicle.vehicle_id %>', '<%= vehicle.type %>', '<%= vehicle.plate_number %>', '<%= vehicle.make %>', '<%= vehicle.model %>', '<%= vehicle.color %>', '<%= vehicle.sticker_year %>', '<%= vehicle.resident_ids || "" %>')">
                                        <i class="fa-solid fa-edit"></i>
                                    </button>

                                    <form action="/vehicles/delete/<%= vehicle.vehicle_id %>" method="POST" style="display:inline;" onsubmit="return confirm('Are you sure you wish to PERMANENTLY remove this vehicle? (This action CANNOT be undone)');">
                                        <button type="submit" class="btn-icon btn-icon-danger">
                                            <i class="fa-solid fa-trash"></i>
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        <% }) %>
                    <% } %>
                </tbody>
            </table>
        </div>
    </main>

    <div id="vehicleModal" class="modal">
        <div class="modal-content">
            <div class="modal-header">
                <h2>Add New Vehicle</h2>
                <button class="modal-close" onclick="document.getElementById('vehicleModal').classList.remove('active')">&times;</button>
            </div>
            <div class="modal-body">
                <form id="vehicleForm" action="/vehicles/register" method="POST">
                    
                    <div class="form-group">
                        <label>Vehicle Type</label>
                        <select id="edit_type" name="type" class="form-control" style="width: 100%; padding: 8px;" required>
                            <option value="">Select Vehicle Type</option>
                            <option value="Car">Car</option>
                            <option value="Motorcycle">Motorcycle</option>
                            <option value="E-Bike">E-Bike</option>
                            <option value="Others">Others</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label>Plate Number</label>
                        <input type="text" name="plate_number" required placeholder="ABC 1234">
                    </div>
                    <div class="form-row">
                        <div class="form-group">
                            <label>Make</label>
                            <input type="text" name="make" placeholder="e.g., Toyota" required>
                        </div>
                        <div class="form-group">
                            <label>Model</label>
                            <input type="text" name="model" placeholder="e.g., Vios" required>
                        </div>
                    </div>
                    <div class="form-row">
                        <div class="form-group">
                            <label>Color</label>
                            <input type="text" name="color" required>
                        </div>
                        <div class="form-group">
                            <label>Sticker Year</label>
                            <input type="number" name="sticker_year" placeholder="2026" required>
                        </div>
                    </div>
                    <div class="form-group" style="margin-top: 15px;">
                        <label>Owners (Check all residents that own this vehicle)</label>
                        
                        <div class="checkbox-list-container" style="max-height: 150px; overflow-y: auto; border: 1px solid #ccc; padding: 10px; border-radius: 4px;">
                            <% if (locals.residents) { %>
                                <% residents.forEach(resident => { %>
                                    <div style="margin-bottom: 5px;">
                                        <input type="checkbox" 
                                            id="edit_res_<%= resident.resident_id %>" 
                                            name="resident_ids" 
                                            value="<%= resident.resident_id %>"
                                            class="resident-checkbox">
                                        <label for="edit_res_<%= resident.resident_id %>" style="display: inline; font-weight: normal; margin-left: 5px;">
                                            <%= resident.full_name %>
                                        </label>
                                    </div>
                                <% }); %>
                            <% } %>
                        </div>
                    </div>
                    
                    <div class="modal-footer" style="margin-top: 20px;">
                        <button type="button" class="btn btn-secondary" onclick="document.getElementById('vehicleModal').classList.remove('active')">Cancel</button>
                        <button type="submit" class="btn btn-primary">Save Vehicle</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<div id="editVehicleModal" class="modal">
    <div class="modal-content">
        <div class="modal-header">
            <h2>Edit Vehicle Details</h2>
            <button class="modal-close" onclick="document.getElementById('editVehicleModal').classList.remove('active')">&times;</button>
        </div>
        <div class="modal-body">
            <form id="editVehicleForm" method="POST">
                <div class="form-group">
                    <label>Plate Number</label>
                    <input type="text" id="edit_plate_number" name="plate_number" required>
                </div>
                <div class="form-group" style="margin-top: 15px;">
                    <label>Vehicle Type</label>
                    <select id="edit_type" name="type" class="form-control" style="width: 100%; padding: 8px;" required>
                        <option value="">Select Vehicle Type</option>
                        <option value="Car">Car</option>
                        <option value="Motorcycle">Motorcycle</option>
                        <option value="E-Bike">E-Bike</option>
                        <option value="Others">Others</option>
                    </select>
                </div>
                <div class="form-group" style="margin-top: 15px;">
                        <label>Owners (Check all residents that own this vehicle)</label>
                        
                        <div class="checkbox-list-container" style="max-height: 150px; overflow-y: auto; border: 1px solid #ccc; padding: 10px; border-radius: 4px;">
                            <% if (locals.residents) { %>
                                <% residents.forEach(resident => { %>
                                    <div style="margin-bottom: 5px;">
                                        <input type="checkbox" 
                                            id="edit_res_<%= resident.resident_id %>" 
                                            name="resident_ids" 
                                            value="<%= resident.resident_id %>"
                                            class="resident-checkbox">
                                        <label for="edit_res_<%= resident.resident_id %>" style="display: inline; font-weight: normal; margin-left: 5px;">
                                            <%= resident.full_name %>
                                        </label>
                                    </div>
                                <% }); %>
                            <% } %>
                        </div>
                    </div>
                <div class="form-row">
                    <div class="form-group">
                        <label>Make</label>
                        <input type="text" id="edit_make" name="make" required>
                    </div>
                    <div class="form-group">
                        <label>Model</label>
                        <input type="text" id="edit_model" name="model" required>
                    </div>
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label>Color</label>
                        <input type="text" id="edit_color" name="color" required>
                    </div>
                    <div class="form-group">
                        <label>Sticker Year</label>
                        <input type="number" id="edit_sticker_year" name="sticker_year">
                    </div>
                </div>
                
                <div class="modal-footer" style="margin-top: 20px;">
                    <button type="button" class="btn btn-secondary" onclick="document.getElementById('editVehicleModal').classList.remove('active')">Cancel
                    </button>
                    <button type="submit" class="btn btn-primary">Update Vehicle</button>
                </div>
            </form>
        </div>
    </div>
</div>


<script>
    function openEditModal(id, type, plate_number, make, model, color, sticker_year, resident_ids_string) {
        
        document.getElementById('editVehicleForm').action = '/vehicles/update/' + id;
        
        document.getElementById('edit_type').value = type || '';
        document.getElementById('edit_plate_number').value = plate_number || '';
        document.getElementById('edit_make').value = make || '';
        document.getElementById('edit_model').value = model || '';
        document.getElementById('edit_color').value = color || '';
        document.getElementById('edit_sticker_year').value = sticker_year || '';
        
        const editForm = document.getElementById('editVehicleForm');
        
        editForm.querySelectorAll('.resident-checkbox').forEach(cb => cb.checked = false);
        
        if (resident_ids_string) {
            const selectedIds = resident_ids_string.split(',');
            
            editForm.querySelectorAll('.resident-checkbox').forEach(cb => {
                if (selectedIds.includes(cb.value)) {
                    cb.checked = true;
                }
            });
        }
        
        document.getElementById('editVehicleModal').classList.add('active');
    }
</script>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        const searchInput = document.getElementById('searchInput');
        const vehicleCountDisplay = document.getElementById('vehicleCount');
        const tableBody = document.querySelector('.data-table tbody');
        
        const rows = tableBody.querySelectorAll('tr:not(:has(.empty-state))'); 

        if (searchInput && rows.length > 0){
            searchInput.addEventListener('input', function(){
                const searchTerm = this.value.toLowerCase().trim();
                let visibleCount = 0;

                rows.forEach(row =>{
                    const rowText = row.textContent.toLowerCase();
                    
                    if (rowText.includes(searchTerm)){
                        row.style.display = '';
                        visibleCount++;
                    }
                    else{
                        row.style.display = 'none';
                    }
                });

                vehicleCountDisplay.textContent = visibleCount;
            });
        }
    });
</script>

<script src="/js/sidebar.js"></script>
