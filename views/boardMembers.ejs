<!-- ============================================================
     BOARD MEMBER VIEW — Full CRUD
     Layout: views/layouts/main.ejs (has sidebar)
     Controller: controllers/board-memberController.js
     Model: models/board-memberModel.js
     Extra CSS: board-member.css (passed via pageCSS in controller)
     ============================================================ -->

<div class="main-wrapper">
    <div class="sidebar-open nav-item">
        <i class="fa-solid fa-bars"></i>
        <span>Open Sidebar</span>
    </div>

    <header class="topbar">
        <div class="topbar-left">
            <h1 class="page-title">Board Members</h1>
            <p class="page-subtitle">View, add, edit, and manage all board members</p>
        </div>
        <div class="topbar-right">
            <div class="topbar-user">
                <div class="user-avatar">
                    <i class="fa-solid fa-user"></i>
                </div>
                <div class="user-info">
                    <span class="user-name">Village Admin</span>
                    <span class="user-role">Administrator</span>
                </div>
            </div>
        </div>
    </header> 
    

    <main class="content"> 
         <% if (typeof success !== 'undefined' && success) { %>
        <div class="alert alert-success">
            <i class="fa-solid fa-circle-check"></i> <%= success %>
        </div>
        <% } %>
        <% if (typeof error !== 'undefined' && error) { %>
            <div class="alert alert-error">
                <i class="fa-solid fa-circle-exclamation"></i> <%= error %>
            </div>
        <% } %>

        <div class="action-buttons">
            <button class="btn btn-primary" onclick="openAddModal()">
                <i class="fa-solid fa-plus"></i> Add Board Member
            </button>
        </div>
    
        <div class="search-bar">
            <input type="text" class="search-input" id="searchInput" 
                placeholder="Search by name, email, or position..." 
                oninput="filterTable()">
        </div>

        <div class="table-container">
            <table class="data-table" id="residentTable">
                <thead>
                    <tr>
                        <th>Resident </th>
                        <th>Position</th>
                        <th>Contact Number</th>
                        <th>Email</th>
                        <th>Start Date</th>
                        <th>End Date</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (boardMembers.length === 0) { %> 
                    <tr>
                        <td colspan="5" class="empty-state">
                            No board member records found. Click "Add Board Member" to create one.
                        </td>
                    </tr>
                    <% } else { %> 
                        <% boardMembers.forEach(boardMember => { %>
                            <tr>
                                <td><strong><%= boardMember.first_name %> <%= boardMember.last_name %></strong></td>
                                <td><%= boardMember.position %></td>
                                <td><%= boardMember.contact_num || '-' %></td>
                                <td><%= boardMember.email || '-' %></td>
                                <td><%= boardMember.board_start_date %></td>
                                <td><%= boardMember.board_end_date %></td>
                            </tr>
                        <% }) %>
                    <% } %> 
                </tbody>
            </table>
        </div>
    </main>
</div>
<!--------------------------------ADD BOARD MEMBER MODAL------------------------------->
<div id="boardMemberModal" class="modal">
    <div class="modal-content">
        <div class="modal-header">
            <h2 id="modalTitle">Add Board Member</h2>
            <button class="modal-close" onclick="closeModal('boardMemberModal')">&times;</button>
        </div>
        <form id="boardMemberForm" method="POST" action="/boardMembers">
            <input type="hidden" id="resident_id" name="board-member_id">
            <div class="modal-body">

                <!-- Personal Information -->
                <div class="form-section">
                    <h3>Personal Information</h3>
                    <hr>
                    
                    <div class="form-row">
                        <div class="form-group">
                            <label for="firstName">First Name *</label>
                            <input type="text" id="firstName" name="first_name" required placeholder="Enter first name" >
                        </div>
                        <div class="form-group">
                            <label for="lastName">Last Name *</label>
                            <input type="text" id="lastName" name="last_name" required placeholder="Enter last name" >
                        </div>
                    </div>
                    
                    <div class="form-row">
                        <div class="form-group">
                            <label for="position">Position *</label>
                            <input type="text" id="position" name="position" required placeholder="Enter position">
                        </div>
                    </div>

                    <div class="form-row">
                        <div class="form-group">
                            <label for="phoneNumber">Phone Number *</label>
                            <input type="tel" id="phoneNumber" name="contact_num" required placeholder="Enter mobile number">
                        </div>
                    </div>

                    <div class="form-group">
                        <label for="email">Email Address *</label>
                        <input type="email" id="email" name="email" placeholder="Enter email address">
                    </div>
 
                </div>
                <!-- Board Member Board Information -->
                <div class="form-section" style="margin-top: 20px;">
                    <h3>Board Member Board Information</h3>
                    <hr>

                    <div class="form-row">
                        <div class="form-group">
                            <label for="board-start-date">Board Start Date *</label>
                            <input type="date" id="board-start-date" name="board_start_date" required>
                        </div>

                        <div class="form-group" id="board-end-container">
                            <label for="board-end-date">Board End Date </label>
                            <input type="date" id="board-end-date" name="board_end_date">
                        </div>
                    </div>
                </div>
            </div>
               
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" onclick="closeModal('boardMemberModal')">Cancel</button>
                <button type="submit" class="btn btn-primary" id="submitBtn">Save Board Member</button>
            </div>
        </form>
    </div>
</div>
<!--------------------------------DELETE MODAL------------------------------->
<div id="deleteModal" class="modal">
    <div class="modal-content" style="max-width: 450px;">
        <div class="modal-header">
            <h2>Delete Board Member</h2>
            <button class="modal-close" onclick="closeModal('deleteModal')">&times;</button>
        </div>
        <div class="modal-body">
            <p>Are you sure you want to delete resident <strong id="deleteBoardMemberName"></strong>?</p>
            <p style="color: #dc3545; font-size: 13px; margin-top: 8px; font-weight: 500;">This operation cannot be undone.</p>
        </div>
        <div class="modal-footer">
            <button type="button" class="btn btn-secondary" onclick="closeModal('deleteModal')">Cancel</button>
            <form id="deleteForm" method="POST">
                <button type="submit" class="btn btn-danger">Delete</button>
            </form>
        </div>
    </div>
</div>
<!--------------------------------VIEW MODAL--------------------------------->
<div id="viewModal" class="modal">
    <div class="modal-content">
        <div class="modal-header">
            <h2>View Summary</h2>
            <button class="modal-close" onclick="closeModal('viewModal')">&times;</button>
        </div>
            
        <div class="modal-body">
            <h3>Personal Information</h3>
            <hr>
            <p><strong>Name:</strong> <span id="view-name">—</span></p>
            <p><strong>Position:</strong> <span id="view-position">—</span></p>
            <p><strong>Email:</strong> <span id="view-email">—</span></p>
            <p><strong>Phone:</strong> <span id="view-phone">—</span></p>

            <h3>board Information</h3>
            <hr>
            <p><strong>Board Start Date:</strong> <span id="view-board-start">—</span></p>
            <p><strong>Board End Date:</strong> <span id="view-board-end">—</span></p>
            
        </div>
    </div>
</div>
<!--------------------------------SCRIPT--------------------------------->
<script src="/js/sidebar.js"></script> <!-- sidebar functionality -->
<script>
    //Modal Actions
    function openAddModal() {
        document.getElementById('modalTitle').textContent = 'Add New Board Member';
        document.getElementById('submitBtn').textContent = 'Add Board Member';
        document.getElementById('boardMemberForm').action = '/boardMembers';
        document.getElementById('boardMemberForm').reset();
        document.getElementById('boardMemberModal').classList.add('active');
    }

    function openEditModal(button) {
        const id = button.dataset.id;

        document.getElementById('modalTitle').textContent = 'Edit Resident';
        document.getElementById('submitBtn').textContent = 'Save Changes';
        document.getElementById('boardMemberForm').action = '/boardMembers/' + id + '/update';

        document.getElementById('resident_id').value = id;
        const firstName = button.dataset.firstname;
        const lastName = button.dataset.lastname; 
        const position = button.dataset.position;             
        const email = button.dataset.email;         
        const phone = button.dataset.phone;    
        const boardStartDate = button.dataset.boardstart;
        const boardEndDate = button.dataset.boardend;    
        
        document.getElementById('firstName').value = firstName;
        document.getElementById('lastName').value = lastName;
        document.getElementById('position').value = position;
        document.getElementById('email').value = email;
        document.getElementById('phoneNumber').value = phone;

        document.getElementById('board-start-date').value = boardStartDate;
        document.getElementById('board-end-date').value = boardEndDate;
       
        
        document.getElementById('boardMemberModal').classList.add('active');
    }
    function openViewModal(button) {
   
        const name = button.dataset.name; 
        const position = button.dataset.position;             
        const email = button.dataset.email;         
        const phone = button.dataset.phone;    
        const boardStartDate = button.dataset.boardstart;
        const boardEndDate = button.dataset.boardend;    
       
        document.getElementById('view-name').textContent = name || '—';
        document.getElementById('view-position').textContent = position || '—';
        document.getElementById('view-email').textContent = email || '—';
        document.getElementById('view-phone').textContent = phone || '—'; 
        document.getElementById('view-board-start').textContent = boardStartDate || '—';
        document.getElementById('view-board-end').textContent = boardEndDate || 'Present';

        document.getElementById('viewModal').classList.add('active');
    }

    function confirmDelete(id, boardMemberName) {
        document.getElementById('deleteBoardMemberName').textContent = boardMemberName;
        document.getElementById('deleteForm').action = '/boardMembers/' + id + '/delete';
        document.getElementById('deleteModal').classList.add('active');
    }


    function closeModal(id) {
        document.getElementById(id).classList.remove('active');
    }

    window.onclick = function(event) {
        const boardMemberModal = document.getElementById("boardMemberModal");
        const deleteModal = document.getElementById("deleteModal");
        const viewModal = document.getElementById("viewModal")
        if (event.target === boardMemberModal) closeModal('boardMemberModal');
        if (event.target === deleteModal) closeModal('deleteModal');
        if (event.target === viewModal) closeModal('viewModal');
    }

    function filterTable() {
        const q = document.getElementById('searchInput').value.toLowerCase();
        document.querySelectorAll('#residentTable tbody tr').forEach(row => {
            if (row.cells.length === 1 && row.cells[0].classList.contains('empty-state')) return; 
            row.style.display = row.textContent.toLowerCase().includes(q) ? '' : 'none';
        });
    }


    setTimeout(() => {
        document.querySelectorAll('.alert').forEach(a => a.style.display = 'none');
    }, 4000);
</script>
