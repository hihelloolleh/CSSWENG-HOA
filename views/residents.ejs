<!-- ============================================================
     RESIDENTS VIEW
     Layout: views/layouts/main.ejs (has sidebar)
     Controller: controllers/residentController.js
     Extra CSS: property-owners.css (passed via pageCSS in controller)
     SPRINT 2+: Loop through owners array from DB.
     ============================================================ -->

<header class="topbar">
    <div class="topbar-left">
        <h1 class="page-title">Residents</h1>
        <p class="page-subtitle">View, add, edit, and manage resident information</p>
    </div>
    <div class="topbar-right">
        <div class="topbar-user">
            <div class="user-avatar">
                <i class="fa-solid fa-user"></i>
            </div>
            <div class="user-info">
                <span class="user-name">Village Admin</span>
                <span class="user-role">Administrator</span>
            </div>
        </div>
    </div>
</header>

<main class="content">

    <% if (typeof success !== 'undefined' && success) { %>
        <div class="alert alert-success">
            <i class="fa-solid fa-circle-check"></i> <%= success %>
        </div>
    <% } %>
    <% if (typeof error !== 'undefined' && error) { %>
        <div class="alert alert-error">
            <i class="fa-solid fa-circle-exclamation"></i> <%= error %>
        </div>
    <% } %>

    <div class="action-buttons" style="margin-bottom: 20px;">
        <button class="btn btn-primary" onclick="openAddModal()">
            <i class="fa-solid fa-plus"></i> Add Resident
        </button>
    </div>

    <div class="search-bar" style="margin-bottom: 20px;">
        <input type="text" class="search-input" id="searchInput" 
               placeholder="Search by name, email, or property..." 
               oninput="filterTable()">
    </div>

    <div class="table-container">
        <table class="data-table" id="residentTable">
            <thead>
                <tr>
                    <th>Resident Name</th>
                    <th>Date of Birth</th>
                    <th>Email</th>
                    <th>Phone Number</th>
                    <th>Board Member Status</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                <% if (residents.length === 0) { %>
                    <tr>
                        <td colspan="6" class="empty-state">
                            No resident records found. Click "Add Resident" to create one.
                        </td>
                    </tr>
                <% } else { %>
                    <% residents.forEach(resident => { %>
                        <tr>
                            <td><strong><%= resident.first_name %> <%= resident.last_name %></strong></td>
                            <td><%= resident.birth_date ? resident.birth_date.toString().substring(0, 10) : '—' %></td>
                            <td><%= resident.email || '—' %></td>
                            <td><%= resident.contact_num || '—' %></td>
                            <td><%= resident.is_board_member === 1 ? 'Yes' : 'No' %></td>
                            <td>

                                <button class="btn-icon"
                                        data-id="<%= resident.resident_id %>"
                                        data-name="<%= resident.first_name %> <%= resident.last_name %>"
                                        data-dob="<%= resident.birth_date ? resident.birth_date.toString().substring(0, 10) : '' %>"
                                        data-email="<%= resident.email || '' %>"
                                        data-phone="<%= resident.contact_num || '' %>"
                                        data-isboard="<%= resident.is_board_member %>"
                                        data-role="<%= resident.position || '' %>"
                                        data-boardstart="<%= resident.board_start_date ? resident.board_start_date.toString().substring(0, 10) : '' %>"
                                        data-boardend="<%= resident.board_end_date ? resident.board_end_date.toString().substring(0, 10) : '' %>"
                                        onclick="openViewModal(this)">
                                    View info
                                </button>
                                <button class="btn-icon" 
                                        data-id="<%= resident.id %>"
                                        data-firstname="<%= resident.first_name %>"
                                        data-lastname="<%= resident.last_name %>"
                                        data-dob="<%= resident.birth_date ? resident.birth_date.toString().substring(0, 10) : '' %>"
                                        data-email="<%= resident.email || '' %>"
                                        data-phone="<%= resident.contact_num || '' %>"
                                        onclick="openEditModal(this.dataset.id, this.dataset.firstname, this.dataset.lastname, this.dataset.dob, this.dataset.email, this.dataset.phone)">
                                    <i class="fa-solid fa-edit"></i>
                                </button>

                                <button class="btn-icon btn-icon-danger" 
                                        data-id="<%= resident.id %>"
                                        data-name="<%= resident.first_name %> <%= resident.last_name %>"
                                        onclick="confirmDelete(this.dataset.id, this.dataset.name)">
                                    <i class="fa-solid fa-trash"></i>
                                </button>
                            </td>
                        </tr>
                    <% }) %>
                <% } %> 
            </tbody>
        </table>
    </div>
</main>
<!--------------------------------ADD RESIDENT MODAL------------------------------->
<div id="residentModal" class="modal">
    <div class="modal-content">
        <div class="modal-header">
            <h2 id="modalTitle">Add Resident</h2>
            <button class="modal-close" onclick="closeModal('residentModal')">&times;</button>
        </div>
        <form id="residentForm" method="POST" action="/residents">
            <div class="modal-body">

                <!-- Personal Information -->
                <div class="form-section">
                    <h3>Personal Information</h3>
                    <hr>
                    
                    <div class="form-row">
                        <div class="form-group">
                            <label for="firstName">First Name *</label>
                            <input type="text" id="firstName" name="first_name" required placeholder="Enter first name">
                        </div>
                        <div class="form-group">
                            <label for="lastName">Last Name *</label>
                            <input type="text" id="lastName" name="last_name" required placeholder="Enter last name">
                        </div>
                    </div>
                    
                    <div class="form-row">
                        <div class="form-group">
                            <label for="dob">Date of Birth *</label>
                            <input type="date" id="dob" name="birth_date" required>
                        </div>
                    </div>
            
                    <div class="form-group">
                        <label for="email">Email Address *</label>
                        <input type="email" id="email" name="email" required placeholder="Enter email address">
                    </div>
                    
                    <div class="form-row">
                        <div class="form-group">
                            <label for="phoneNumber">Phone Number *</label>
                            <input type="tel" id="phoneNumber" name="contact_num" required placeholder="Enter mobile number">
                        </div>
                    </div>
                </div>
                <!-- Property / Residential Information -->
                <div class="form-section" style="margin-top: 20px;">
                    <h3>Property / Residential Information</h3>
                    <hr>
                    
                <!-- Vehicle Information -->
                    <h3>Vehicle Informationn</h3>
                    <hr>

                <!-- Board Member Status -->
                    <h3>Board Member Status</h3>
                    <hr>
                    <div class="form-row">
                        <div class="form-group">
                            <label>Is Board Member *</label>
                            <div class="radio-group">
                                <input type="radio" id="yes" name="is_board_member" value="1">
                                <label for="yes">Yes</label>
                                
                                <input type="radio" id="no" name="is_board_member" value="0">
                                <label for="no">No</label>
                            </div>
                        </div>
                    </div>

                    <div id="conditional-questions" style="display: none;">
                        <div class="form-row">
                            <div class="form-group">
                                <label for="board_role">Board Position *</label>
                                  <select name="position" id="position">
                                    <option value="President">President</option>
                                    <option value="Vice President">Vice President</option>
                                    <option value="Secretary">Secretary</option>
                                    <option value="Treasurer">Treasurer</option>
                                    <option value="Board Member">Board Member</option>
                                </select>
                            </div>
                            <div class="form-group">
                                <label for="board_years">Start Date </label>
                                <input type="date" id="board_start_date" name="board_start_date">
                            </div>
                        </div>
                    </div>
                </div>
                
            </div>

            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" onclick="closeModal('residentModal')">Cancel</button>
                <button type="submit" class="btn btn-primary" id="submitBtn">Save Resident</button>
            </div>
        </form>
    </div>
</div>
<!--------------------------------DELETE MODAL------------------------------->
<div id="deleteModal" class="modal">
    <div class="modal-content" style="max-width: 450px;">
        <div class="modal-header">
            <h2>Delete Resident</h2>
            <button class="modal-close" onclick="closeModal('deleteModal')">&times;</button>
        </div>
        <div class="modal-body">
            <p>Are you sure you want to delete resident <strong id="deleteResidentName"></strong>?</p>
            <p style="color: #dc3545; font-size: 13px; margin-top: 8px; font-weight: 500;">This operation cannot be undone.</p>
        </div>
        <div class="modal-footer">
            <button type="button" class="btn btn-secondary" onclick="closeModal('deleteModal')">Cancel</button>
            <form id="deleteForm" method="POST">
                <button type="submit" class="btn btn-danger">Delete</button>
            </form>
        </div>
    </div>
</div>
<!--------------------------------VIEW MODAL--------------------------------->
<div id="viewModal" class="modal">
    <div class="modal-content">
        <div class="modal-header">
            <h2>View Summary</h2>
            <button class="modal-close" onclick="closeModal('viewModal')">&times;</button>
        </div>
            
        <div class="modal-body">
            <h3>Personal Information</h3>
            <hr>
            <p><strong>Name:</strong> <span id="view-name">—</span></p>
            <p><strong>Date of Birth:</strong> <span id="view-dob">—</span></p>
            <p><strong>Email:</strong> <span id="view-email">—</span></p>
            <p><strong>Phone:</strong> <span id="view-phone">—</span></p>
            <div id="view-role-container" style="display: none;">
                <h3>Board Member Information</h3>
                <hr>
                <p><strong>Board Member Role:</strong> <span id="view-role">—</span></p>
                <p><strong>Term Start Date:</strong> <span id="view-boardstart">—</span></p>
                <p><strong>Term End Date:</strong> <span id="view-boardend">—</span></p>
            </div>
        </div>
    </div>
</div>
<!--------------------------------SCRIPT--------------------------------->
<script>
    //Modal Actions
    function openAddModal() {
        document.getElementById('modalTitle').textContent = 'Add New Resident';
        document.getElementById('submitBtn').textContent = 'Add Resident';
        document.getElementById('residentForm').action = '/residents';
        document.getElementById('residentForm').reset();
        document.getElementById('residentModal').classList.add('active');
    }

    function openEditModal(id, firstName, lastName, dob, email, phoneNumber) {
        document.getElementById('modalTitle').textContent = 'Edit Resident';
        document.getElementById('submitBtn').textContent = 'Save Changes';
        document.getElementById('residentForm').action = '/residents/' + id + '/update';
        
        document.getElementById('firstName').value = firstName;
        document.getElementById('lastName').value = lastName;
        document.getElementById('dob').value = dob;
        document.getElementById('email').value = email;
        document.getElementById('phoneNumber').value = phoneNumber;
        
        document.getElementById('residentModal').classList.add('active');
    }
    function openViewModal(button) {
   
        const name = button.dataset.name; 
        const dob = button.dataset.dob;             
        const email = button.dataset.email;         
        const phone = button.dataset.phone;        

        const isBoard = button.dataset.isboard; 
        const boardRole = button.dataset.role;
        const boardStart = button.dataset.boardstart;
        const boardEnd = button.dataset.boardend;
       
        document.getElementById('view-name').textContent = name || '—';
        document.getElementById('view-dob').textContent = dob || '—';
        document.getElementById('view-email').textContent = email || '—';
        document.getElementById('view-phone').textContent = phone || '—'; 

        const roleContainer = document.getElementById('view-role-container');
    
        if (isBoard === "1") {
            document.getElementById('view-role').textContent = boardRole || '—';
            document.getElementById('view-boardstart').textContent = boardStart || '—';
            document.getElementById('view-boardend').textContent = boardEnd || 'Present'; 
            
            roleContainer.style.display = 'block'; 
        } else {
            roleContainer.style.display = 'none'; 
        }

       
        document.getElementById('viewModal').classList.add('active');
    }

    function confirmDelete(id, residentName) {
        document.getElementById('deleteResidentName').textContent = residentName;
        document.getElementById('deleteForm').action = '/residents/' + id + '/delete';
        document.getElementById('deleteModal').classList.add('active');
    }

    function closeModal(id) {
        document.getElementById(id).classList.remove('active');
    }

    window.onclick = function(event) {
        const residentModal = document.getElementById("residentModal");
        const deleteModal = document.getElementById("deleteModal");
        if (event.target === residentModal) closeModal('residentModal');
        if (event.target === deleteModal) closeModal('deleteModal');
    }

    function filterTable() {
        const q = document.getElementById('searchInput').value.toLowerCase();
        document.querySelectorAll('#residentTable tbody tr').forEach(row => {
            if (row.cells.length === 1 && row.cells[0].classList.contains('empty-state')) return; 
            row.style.display = row.textContent.toLowerCase().includes(q) ? '' : 'none';
        });
    }
    //Displays additional questions if resident is a board member
    document.addEventListener("DOMContentLoaded", function () {
        const yesRadio = document.getElementById("yes");
        const noRadio = document.getElementById("no");
        const conditionalSection = document.getElementById("conditional-questions");

        function toggleQuestions() {
            if (yesRadio.checked) {
                conditionalSection.style.display = "block";
            } else {
                conditionalSection.style.display = "none";
            }
        }

        yesRadio.addEventListener("change", toggleQuestions);
        noRadio.addEventListener("change", toggleQuestions);
    });

    setTimeout(() => {
        document.querySelectorAll('.alert').forEach(a => a.style.display = 'none');
    }, 4000);
</script>