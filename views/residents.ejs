<!-- ============================================================
     RESIDENTS VIEW
     Layout: views/layouts/main.ejs (has sidebar)
     Controller: controllers/residentController.js
     Extra CSS: property-owners.css (passed via pageCSS in controller)
     SPRINT 2+: Loop through owners array from DB.
     ============================================================ -->

<header class="topbar">
    <div class="topbar-left">
        <h1 class="page-title">Residents</h1>
        <p class="page-subtitle">View, add, edit, and manage resident information</p>
    </div>
    <div class="topbar-right">
        <div class="topbar-user">
            <div class="user-avatar">
                <i class="fa-solid fa-user"></i>
            </div>
            <div class="user-info">
                <span class="user-name">Village Admin</span>
                <span class="user-role">Administrator</span>
            </div>
        </div>
    </div>
</header>

<main class="content">

    <% if (typeof success !== 'undefined' && success) { %>
        <div class="alert alert-success"><i class="fa-solid fa-circle-check"></i> <%= success %></div>
    <% } %>
    <% if (typeof error !== 'undefined' && error) { %>
        <div class="alert alert-error"><i class="fa-solid fa-circle-exclamation"></i> <%= error %></div>
    <% } %>

    <div class="toolbar" style="display: flex; gap: 16px; margin-bottom: 20px; align-items: center;">
        <button class="btn btn-primary" onclick="openAddModal()">
            <i class="fa-solid fa-plus"></i> Add Resident
        </button>
    </div>

    <div class="search-bar" style="margin-bottom: 20px;">
        <input type="text" class="search-input" placeholder="Search by name, email, or property..." id="searchInput" oninput="filterTable()" style="width: 100%; padding: 8px 12px; border: 1px solid #ccc; border-radius: 4px;">
    </div>

    <div class="table-container">
        <table class="data-table" id="residentTable">
            <thead>
                <tr>
                    <th>Resident Name</th>
                    <th>Type</th>
                    <th>Date of Birth</th>
                    <th>Property Address</th>
                    <th>Lot Number</th>
                    <th>Email</th>
                    <th>Phone Number</th>
                    <th>Landline</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                <% if (residents.length === 0) { %>
                    <tr>
                        <td colspan="9" style="text-align: center; padding: 32px; color: #888;">
                            No resident records found. Click "Add Resident" to create one.
                        </td>
                    </tr>
                <% } else { %>
                    <% residents.forEach(resident => { %>
                        <tr>
                            <td><strong><%= resident.first_name %> <%= resident.last_name %></strong></td>
                            <td><%= resident.type || 'Resident' %></td>
                            <td><%= resident.birth_date ? resident.birth_date.toString().substring(0, 10) : '—' %></td>
                            <td><%= resident.address || '—' %></td>
                            <td><%= resident.lot_number || '—' %></td>
                            <td><%= resident.email || '—' %></td>
                            <td><%= resident.contact_num || '—' %></td>
                            <td><%= resident.landline || '—' %></td>
                            <td>
                                <button class="btn-icon" 
                                        onclick="openEditModal(
                                            '<%= resident.id %>',
                                            '<%= resident.first_name.replace(/'/g, "\\'") %>',
                                            '<%= resident.last_name.replace(/'/g, "\\'") %>',
                                            '<%= (resident.type || 'Resident').replace(/'/g, "\\'") %>',
                                            '<%= resident.birth_date ? resident.birth_date.toString().substring(0, 10) : '' %>',
                                            '<%= (resident.address || '').replace(/'/g, "\\'") %>',
                                            '<%= (resident.lot_number || '').replace(/'/g, "\\'") %>',
                                            '<%= (resident.email || '').replace(/'/g, "\\'") %>',
                                            '<%= (resident.contact_num || '').replace(/'/g, "\\'") %>',
                                            '<%= (resident.landline || '').replace(/'/g, "\\'") %>'
                                        )">
                                    <i class="fa-solid fa-pen-to-square"></i>
                                </button>
                                <button class="btn-icon btn-icon-danger" 
                                        onclick="confirmDelete('<%= resident.id %>', '<%= resident.first_name.replace(/'/g, "\\'") %> <%= resident.last_name.replace(/'/g, "\\'") %>')">
                                    <i class="fa-solid fa-trash"></i>
                                </button>
                            </td>
                        </tr>
                    <% }) %>
                <% } %> 
            </tbody>
        </table>
    </div>
</main>

<div id="residentModal" class="modal-overlay" style="display:none;">
    <div class="modal">
        <div class="modal-header">
            <h2 id="modalTitle">Add Resident</h2>
            <button class="modal-close" onclick="closeModal('residentModal')">&times;</button>
        </div>
        <form id="residentForm" method="POST" action="/residents">
            <div class="modal-body">
                <div class="form-row" style="display: flex; gap: 16px; margin-bottom: 12px;">
                    <div class="form-group" style="flex: 1;">
                        <label>First Name *</label>
                        <input type="text" id="firstName" name="first_name" required placeholder="Enter first name" class="form-control" style="width: 100%;">
                    </div>
                    <div class="form-group" style="flex: 1;">
                        <label>Last Name *</label>
                        <input type="text" id="lastName" name="last_name" required placeholder="Enter last name" class="form-control" style="width: 100%;">
                    </div>
                </div>
                <div class="form-row" style="display: flex; gap: 16px; margin-bottom: 12px;">
                    <div class="form-group" style="flex: 1;">
                        <label>Resident Type *</label>
                        <input type="text" id="type" name="type" required placeholder="e.g. Homeowner, Tenant" class="form-control" style="width: 100%;"> 
                    </div>
                    <div class="form-group" style="flex: 1;">
                        <label>Date of Birth *</label>
                        <input type="date" id="dob" name="birth_date" required class="form-control" style="width: 100%;">
                    </div>
                </div>
                <div class="form-row" style="display: flex; gap: 16px; margin-bottom: 12px;">
                    <div class="form-group" style="flex: 2;">
                        <label>Property Address *</label>
                        <input type="text" id="address" name="address" required placeholder="Enter property address" class="form-control" style="width: 100%;">
                    </div>
                    <div class="form-group" style="flex: 1;">
                        <label>Lot Number *</label>
                        <input type="text" id="lotNumber" name="lot_number" required placeholder="Enter lot number" class="form-control" style="width: 100%;">
                    </div>
                </div>
                <div class="form-group" style="margin-bottom: 12px;">
                    <label>Email Address *</label>
                    <input type="email" id="email" name="email" required placeholder="Enter email address" class="form-control" style="width: 100%;">
                </div>
                <div class="form-row" style="display: flex; gap: 16px; margin-bottom: 16px;">
                    <div class="form-group" style="flex: 1;">
                        <label>Phone Number *</label>
                        <input type="tel" id="phoneNumber" name="contact_num" required placeholder="Enter mobile number" class="form-control" style="width: 100%;">
                    </div>
                    <div class="form-group" style="flex: 1;">
                        <label>Landline Number</label>
                        <input type="tel" id="landline" name="landline" placeholder="Enter landline (optional)" class="form-control" style="width: 100%;">
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" onclick="closeModal('residentModal')">Cancel</button>
                <button type="submit" class="btn btn-primary" id="submitBtn">Save Resident</button>
            </div>
        </form>
    </div>
</div>

<div id="deleteModal" class="modal-overlay" style="display:none;">
    <div class="modal modal-sm">
        <div class="modal-header">
            <h2>Delete Resident</h2>
            <button class="modal-close" onclick="closeModal('deleteModal')">&times;</button>
        </div>
        <div class="modal-body">
            <p>Are you sure you want to delete resident <strong id="deleteResidentName"></strong>?</p>
            <p style="color: red; font-size: 0.9em; margin-top: 4px;">This operation cannot be undone.</p>
        </div>
        <div class="modal-footer">
            <button class="btn btn-secondary" onclick="closeModal('deleteModal')">Cancel</button>
            <form id="deleteForm" method="POST">
                <button type="submit" class="btn btn-danger">Delete</button>
            </form>
        </div>
    </div>
</div>

<script>
    //Modal helpers
    function openAddModal() {
        document.getElementById('modalTitle').textContent = 'Add Resident';
        document.getElementById('submitBtn').textContent = 'Add Resident';
        document.getElementById('residentForm').action = '/residents';
        document.getElementById('residentForm').reset();
        document.getElementById('residentModal').style.display = 'flex';
    }

    function openEditModal(id, firstName, lastName, type, dob, address, lotNumber, email, phoneNumber, landline) {
        document.getElementById('modalTitle').textContent = 'Edit Resident';
        document.getElementById('submitBtn').textContent = 'Save Changes';
        document.getElementById('residentForm').action = '/residents/' + id + '/update';
        
        document.getElementById('firstName').value = firstName;
        document.getElementById('lastName').value = lastName;
        document.getElementById('type').value = type;
        document.getElementById('dob').value = dob;
        document.getElementById('address').value = address;
        document.getElementById('lotNumber').value = lotNumber;
        document.getElementById('email').value = email;
        document.getElementById('phoneNumber').value = phoneNumber;
        document.getElementById('landline').value = landline;
        
        document.getElementById('residentModal').style.display = 'flex';
    }

    function confirmDelete(id, residentName) {
        document.getElementById('deleteResidentName').textContent = residentName;
        document.getElementById('deleteForm').action = '/residents/' + id + '/delete';
        document.getElementById('deleteModal').style.display = 'flex';
    }

    function closeModal(id) {
        document.getElementById(id).style.display = 'none';
    }

    
    document.querySelectorAll('.modal-overlay').forEach(overlay => {
        overlay.addEventListener('click', function(e) {
            if (e.target === this) closeModal(this.id);
        });
    });

    //Search filter
    function filterTable() {
        const q = document.getElementById('searchInput').value.toLowerCase();
        document.querySelectorAll('#residentTable tbody tr').forEach(row => {
            if (row.cells.length === 1) return; 
            row.style.display = row.textContent.toLowerCase().includes(q) ? '' : 'none';
        });
    }


    setTimeout(() => {
        document.querySelectorAll('.alert').forEach(a => a.style.display = 'none');
    }, 4000);
</script>