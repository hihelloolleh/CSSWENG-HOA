<!-- ============================================================
        PAYMENTS VIEW
        Layout: views/layouts/payments.ejs 
        Model: models/paymentModel.js (NOT IMPLEMENTED)
        Controller: controllers/paymentController.js
        Routes: routes/paymentRoutes.js 
        Services: services/paymentServices.js (NOT IMPLEMENTED)
        CSS: payments.css 
    ============================================================ -->

<div class="main-wrapper"> 
    <div class="sidebar-open nav-item"> 
        <i class="fa-solid fa-bars"></i>
        <span>Open Sidebar</span>
    </div>

    <header class="topbar">
        <div class="topbar-left"> 
            <h1 class="page-title">Payments</h1>
        </div>
        <div class="topbar-right">
            <div class="topbar-user">
                <div class="user-avatar">
                    <i class="fa-solid fa-user"></i>
                </div>
                <div class="user-info">
                    <span class="user-name">Village Admin</span>
                    <span class="user-role">Administrator</span>
                </div>
            </div>
        </div>
    </header>

    <main class="content">
        <button class="btn btn-primary back-btn" onclick="window.location.href='/payments';"> 
            ← Back to Payment Ledger         
        </button>

        <div class="payment-modal">
            <div class="modal-header">
                <h1>
                    <% if (paymentType === "association") { %>
                        Association Dues Payment
                    <% } else if (paymentType === "vehicle") { %>
                        Vehicle Sticker Payment
                    <% } else if (paymentType === "outstanding") { %>
                        Outstanding Balances Payment                  
                    <% } else { %>
                        General Payments
                    <% } %>
                </h1>
            </div>
        
            <div class="modal-body">
                <form method="POST" action="/payments">
                    <% if (paymentType === "association") { %>
                        <div class="form-group">
                            <label>Property Owner</label> 
                            <div class="search-bar">
                                <input class="search-input" type="text" name="property_owner" placeholder="Search by first name, last name, or email...">
                            </div>
                        </div>

                        <div class="form-row">
                            <div class="form-group">
                            <label>Property Type</label>
                            <select name="property_type">
                                <option>House</option>
                                <option>Lot</option>
                            </select>
                            </div>
                            <div class="form-group">
                                <label>Street Name</label>
                                <select name="street-name">
                                    <option>Alabastro</option>
                                    <option>Cameo</option>
                                    <option>Coral</option>
                                    <option>Diamante</option>
                                    <option>Esmeralda</option>
                                </select>
                            </div>
                        </div>
                            
                        <div class="form-row">
                            <div class="form-group">
                                <label>Expected Amount</label>
                                <input type="text" name="unit_lot" placeholder="1500.00 PHP">
                            </div>

                            <div class="form-group"> 
                                <label>Amount</label>
                                <input type="number" name="amount">
                            </div>
                        </div>
                        
                    <% } else if (paymentType === "vehicle") { %>
                    
                        <div class="form-group"> 
                            <label>Vehicle Owner</label>
                            <input type="text" name="vehicle_owner">
                        </div>

                        <div class="form-row">
                            <div class="form-group">
                                <label>Vehicle Type</label>
                                <select name="vehicle_type">
                                    <option>Sedan</option>
                                    <option>SUV</option>
                                    <option>Motorcycle</option>
                                </select>
                            </div>
                        
                            <div class="form-group"> 
                                <label>Plate Number</label>
                                <input type="number" name="plate_number">
                            </div>
                        </div>
                        
                    <% } else if (paymentType === "outstanding") { %>
                        <div class="form-group">
                            <label>Name</label>
                            <input type="text" name="name">
                        </div>
                        
                        <div class="form-group">
                            <label>Payment Type</label>
                            <select name="type">
                                <option>Late Payment</option>
                                <option>Illegal Parking</option>
                                <option>Noise Complaint</option>
                                <option>Other</option>
                            </select>
                        </div>
                    <% } else { %>
                        <div class="form-group">
                            <label>Name</label>
                            <input type="text" name="name">
                        </div>
                        
                        <div class="form-group">
                            <label>Payment Type</label>
                            <select name="type">
                                <option>Late Payment</option>
                                <option>Illegal Parking</option>
                                <option>Noise Complaint</option>
                                <option>Other</option>
                            </select>
                        </div>  
                    <% } %> 

                    <div class="form-group">
                        <label>Payment Method</label>
                        <select name="payment_method">
                            <option>Cash</option>
                            <option>GCash</option>
                            <option>Bank Transfer</option>
                        </select>
                    </div>
                    
                    <div class="form-group">
                        <label>Remarks</label>
                        <textarea name="remarks"></textarea>
                    </div>

                    <div class="modal-footer">
                        <button class="btn btn-primary" type="submit"> Save Payment </button>
                    </div>
                </form>
            </div>
        </div>
    </main>
</div>

<script src="/js/sidebar.js"></script>
