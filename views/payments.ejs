<div class="main-wrapper">
    <div class="sidebar-open nav-item">
        <i class="fa-solid fa-bars"></i>
        <span>Open Sidebar</span>
    </div>

    <header class="topbar">
        <div class="topbar-left">
            <h1 class="page-title">Payments</h1>
        </div>
        <div class="topbar-right">
            <div class="topbar-user">
                <div class="user-avatar"><i class="fa-solid fa-user"></i></div>
                <div class="user-info">
                    <span class="user-name">Village Admin</span>
                    <span class="user-role">Administrator</span>
                </div>
            </div>
        </div>
    </header>

    <main class="content">
        <button class="btn btn-secondary back-btn" onclick="window.location.href='/payments';">
            &#8592; Back to Payment Ledger
        </button>

        <div class="payment-modal">
            <div class="modal-header">
                <h1>
                    <% if (paymentType === 'association') { %>Association Dues Payment
                    <% } else if (paymentType === 'vehicle') { %>Vehicle Sticker Payment
                    <% } else if (paymentType === 'outstanding') { %>Outstanding Balances Payment
                    <% } else { %>General Payments
                    <% } %>
                </h1>
            </div>

            <div class="modal-body">
                <form method="POST" action="/payments">
                    <!-- maps URL param to DB enum value -->
                    <input type="hidden" name="purpose" value="<%= purposeValue %>">

                    <% if (paymentType === 'association') { %>
                        <div class="form-group">
                            <label>Property</label>
                            <div class="resident-search-wrap">
                                <input type="text" id="property_search" class="search-input" placeholder="Search by lot number or street..." autocomplete="off">
                                <ul id="property_dropdown" class="resident-dropdown-list"></ul>
                            </div>
                            <input type="hidden" id="property_id" name="property_id">
                        </div>

                        <div class="form-group">
                            <label>Homeowner / Payer</label>
                            <div class="resident-search-wrap">
                                <input type="text" id="payer_search" class="search-input" placeholder="Select a property first" autocomplete="off">
                                <ul id="payer_dropdown" class="resident-dropdown-list"></ul>
                            </div>
                            <input type="hidden" id="paid_by" name="paid_by">
                            <small id="payer_hint" style="color:#888; font-size:12px; margin-top:4px; display:block;">Select a property first</small>
                        </div>

                        <div class="form-row">
                            <div class="form-group">
                                <label>Payment Type</label>
                                <select name="payment_type" class="form-control">
                                    <option value="monthly">Monthly</option>
                                    <option value="annual">Annual</option>
                                </select>
                            </div>
                            <div class="form-group">
                                <label>Months</label>
                                <select name="months" class="form-control">
                                    <% for (let m = 1; m <= 11; m++) { %>
                                        <option value="<%= m %>"><%= m %></option>
                                    <% } %>
                                </select>
                            </div>
                        </div>

                    <% } else if (paymentType === 'vehicle') { %>
                        <div class="form-group">
                            <label>Vehicle Owner / Payer</label>
                            <div class="resident-search-wrap">
                                <input type="text" id="payer_search" class="search-input" placeholder="Search by name..." autocomplete="off">
                                <ul id="payer_dropdown" class="resident-dropdown-list"></ul>
                            </div>
                            <input type="hidden" id="paid_by" name="paid_by">
                        </div>

                        <div class="form-group">
                            <label>Vehicle</label>
                            <div class="resident-search-wrap">
                                <input type="text" id="vehicle_search" class="search-input" placeholder="Search by plate number..." autocomplete="off">
                                <ul id="vehicle_dropdown" class="resident-dropdown-list"></ul>
                            </div>
                            <input type="hidden" id="vehicle_id" name="vehicle_id">
                        </div>

                    <% } else if (paymentType === 'outstanding') { %>
                        <div class="form-group">
                            <label>Property</label>
                            <div class="resident-search-wrap">
                                <input type="text" id="property_search" class="search-input" placeholder="Search by lot number or street..." autocomplete="off">
                                <ul id="property_dropdown" class="resident-dropdown-list"></ul>
                            </div>
                            <input type="hidden" id="property_id" name="property_id">
                            <small id="outstanding_hint" style="color:#888; font-size:12px; margin-top:4px; display:block;">Select a property to see its current outstanding balance</small>
                        </div>

                        <div class="form-group">
                            <label>Payer</label>
                            <div class="resident-search-wrap">
                                <input type="text" id="payer_search" class="search-input" placeholder="Select a property first" autocomplete="off">
                                <ul id="payer_dropdown" class="resident-dropdown-list"></ul>
                            </div>
                            <input type="hidden" id="paid_by" name="paid_by">
                            <small id="payer_hint" style="color:#888; font-size:12px; margin-top:4px; display:block;">Select a property first</small>
                        </div>

                        <div class="form-row">
                            <div class="form-group">
                                <label>Outstanding Balance (Expected)</label>
                                <input type="number" step="0.01" id="amount_expected" name="amount_expected"
                                       class="form-control" readonly placeholder="Auto-filled from property"
                                       style="background:#f5f5f5;">
                            </div>
                            <div class="form-group">
                                <label>Amount Paid *</label>
                                <input type="number" step="0.01" name="amount_paid" class="form-control" required>
                            </div>
                        </div>

                        <div class="form-group">
                            <label>Date Paid *</label>
                            <input type="date" name="date_paid" class="form-control" required>
                        </div>

                        <div class="form-row">
                            <div class="form-group">
                                <label>Payment Method *</label>
                                <select name="payment_method" class="form-control" required>
                                    <option value="Cash">Cash</option>
                                    <option value="Check">Check</option>
                                    <option value="Bank Transfer">Bank Transfer</option>
                                    <option value="GCash">GCash</option>
                                    <option value="Maya">Maya</option>
                                </select>
                            </div>
                            <div class="form-group">
                                <label>Receipt Number</label>
                                <input type="text" name="receipt_number" class="form-control">
                            </div>
                        </div>

                        <div class="form-group">
                            <label>Remarks</label>
                            <textarea name="remarks" class="form-control" rows="3" style="width:100%; resize:vertical;"></textarea>
                        </div>

                        <div class="modal-footer">
                            <button class="btn btn-primary" type="submit">Record Payment</button>
                        </div>

                    <% } else { %>
                        <div class="form-group">
                            <label>Payment Sub-type</label>
                            <select name="payment_subtype" class="form-control">
                                <option value="basketball_rental">Basketball Court Rental</option>
                                <option value="racquet_rental">Racquet Court Rental</option>
                                <option value="football_rental">Football Field Rental</option>
                                <option value="clubhouse_rental">Clubhouse Rental</option>
                                <option value="tables_rental">Tables and Chair Rental</option>
                                <option value="endorsement_letter">Endorsement Letter</option>
                                <option value="construction_fee">Construction Fee</option>
                                <option value="construction_bond">Construction Bond</option>
                                <option value="renovation_fee">Renovation Fee</option>
                                <option value="penalty">Penalty</option>
                                <option value="donation">Donation</option>
                                <option value="bulletin_fee">Bulletin Board Fee</option>
                                <option value="other">Other</option>
                            </select>
                        </div>

                        <div class="form-group">
                            <label>Payer</label>
                            <div class="resident-search-wrap">
                                <input type="text" id="payer_search" class="search-input" placeholder="Search by name..." autocomplete="off">
                                <ul id="payer_dropdown" class="resident-dropdown-list"></ul>
                            </div>
                            <input type="hidden" id="paid_by" name="paid_by">
                        </div>
                    <% } %>

                    <% if (paymentType !== 'outstanding') { %>
                        <div class="form-row">
                            <div class="form-group">
                                <label>Expected Amount</label>
                                <% if (paymentType === 'general') { %>
                                    <input type="number" step="0.01" name="amount_expected" class="form-control">
                                <% } else { %>
                                    <input type="number" step="0.01" name="amount_expected" class="form-control" placeholder="Auto-filled" disabled>
                                <% } %>
                            </div>
                            <div class="form-group">
                                <label>Amount Paid</label>
                                <input type="number" step="0.01" name="amount_paid" class="form-control" required>
                            </div>
                        </div>

                        <div class="form-group">
                            <label>Date Paid</label>
                            <input type="date" name="date_paid" class="form-control" required>
                        </div>

                        <div class="form-row">
                            <div class="form-group">
                                <label>Payment Method</label>
                                <select name="payment_method" class="form-control">
                                    <option value="Cash">Cash</option>
                                    <option value="Check">Check</option>
                                    <option value="Bank Transfer">Bank Transfer</option>
                                    <option value="GCash">GCash</option>
                                    <option value="Maya">Maya</option>
                                </select>
                            </div>
                            <div class="form-group">
                                <label>Receipt Number</label>
                                <input type="text" name="receipt_number" class="form-control">
                            </div>
                        </div>

                        <div class="form-group">
                            <label>Remarks</label>
                            <textarea name="remarks" class="form-control" rows="3" style="width:100%; resize:vertical;"></textarea>
                        </div>

                        <div class="modal-footer">
                            <button class="btn btn-primary" type="submit">Save Payment</button>
                        </div>
                    <% } %>
                </form>
            </div>
        </div>
    </main>
</div>

<!-- Embedded data for search dropdowns -->
<script id="personData"            type="application/json"><%- JSON.stringify(persons)             %></script>
<script id="propertyData"          type="application/json"><%- JSON.stringify(properties)          %></script>
<script id="vehicleData"           type="application/json"><%- JSON.stringify(vehicles)            %></script>
<script id="residentsByPropertyData" type="application/json"><%- JSON.stringify(residentsByProperty) %></script>

<script src="/js/sidebar.js"></script>
<script>
    // ── Load embedded data ────────────────────────────────────────────────────
    const allPersons            = JSON.parse(document.getElementById('personData').textContent);
    const allProperties         = JSON.parse(document.getElementById('propertyData').textContent);
    const allVehicles           = JSON.parse(document.getElementById('vehicleData').textContent);
    const residentsByProperty   = JSON.parse(document.getElementById('residentsByPropertyData').textContent);

    let selectedPropertyId = null;

    // ── Generic searchable dropdown initializer ───────────────────────────────
    function initSearch(inputId, dropdownId, hiddenId, getItems, labelFn, valueFn) {
        const input    = document.getElementById(inputId);
        const dropdown = document.getElementById(dropdownId);
        const hidden   = document.getElementById(hiddenId);
        if (!input) return;

        input.addEventListener('input', function () {
            const q = this.value.trim().toLowerCase();
            hidden.value = '';
            dropdown.innerHTML = '';
            if (!q) { dropdown.style.display = 'none'; return; }

            const matches = getItems().filter(item => labelFn(item).toLowerCase().includes(q));
            if (!matches.length) { dropdown.style.display = 'none'; return; }

            matches.forEach(item => {
                const li = document.createElement('li');
                li.textContent = labelFn(item);
                li.addEventListener('mousedown', function (e) {
                    e.preventDefault();
                    input.value            = labelFn(item);
                    hidden.value           = valueFn(item);
                    dropdown.style.display = 'none';
                });
                dropdown.appendChild(li);
            });
            dropdown.style.display = 'block';
        });

        input.addEventListener('blur', () => {
            setTimeout(() => { dropdown.style.display = 'none'; }, 150);
        });
    }

    // ── Wire up dropdowns based on payment type ───────────────────────────────

    // Property search — on select, reset payer and lock it to that property's residents
    if (document.getElementById('property_search')) {
        const propInput    = document.getElementById('property_search');
        const propDropdown = document.getElementById('property_dropdown');
        const propHidden   = document.getElementById('property_id');
        const payerInput   = document.getElementById('payer_search');
        const payerHint    = document.getElementById('payer_hint');

        propInput.addEventListener('input', function () {
            const q = this.value.trim().toLowerCase();
            propHidden.value = '';
            selectedPropertyId = null;
            propDropdown.innerHTML = '';

            // Reset payer when property changes
            if (payerInput) {
                payerInput.value = '';
                document.getElementById('paid_by').value = '';
                if (payerHint) payerHint.textContent = 'Select a property first';
            }

            if (!q) { propDropdown.style.display = 'none'; return; }

            const matches = allProperties.filter(p =>
                (`Lot ${p.lot_number} ${p.street_name}`).toLowerCase().includes(q)
            );
            if (!matches.length) { propDropdown.style.display = 'none'; return; }

            matches.forEach(prop => {
                const li = document.createElement('li');
                li.textContent = `Lot ${prop.lot_number} — ${prop.street_name}`;
                li.addEventListener('mousedown', function (e) {
                    e.preventDefault();
                    propInput.value        = `Lot ${prop.lot_number} — ${prop.street_name}`;
                    propHidden.value       = prop.property_id;
                    selectedPropertyId     = String(prop.property_id);
                    propDropdown.style.display = 'none';

                    // Auto-fill outstanding balance for the outstanding type
                    const amountExpected = document.getElementById('amount_expected');
                    if (amountExpected) {
                        const bal = parseFloat(prop.outstandingBalance || 0);
                        amountExpected.value = bal.toFixed(2);
                        const hint = document.getElementById('outstanding_hint');
                        if (hint) {
                            hint.textContent = prop.hasDues
                                ? `Current outstanding balance: ₱${bal.toLocaleString('en-PH', {minimumFractionDigits:2})}`
                                : 'This property has no recorded outstanding dues.';
                            hint.style.color = prop.hasDues ? '#c77b00' : '#888';
                        }
                    }

                    // Reset payer and update hint
                    if (payerInput) {
                        payerInput.value = '';
                        document.getElementById('paid_by').value = '';
                        const residents = residentsByProperty[selectedPropertyId] || [];
                        if (payerHint) {
                            payerHint.textContent = residents.length
                                ? `${residents.length} resident(s) in this property`
                                : 'No residents linked to this property';
                        }
                    }
                });
                propDropdown.appendChild(li);
            });
            propDropdown.style.display = 'block';
        });

        propInput.addEventListener('blur', () => {
            setTimeout(() => { propDropdown.style.display = 'none'; }, 150);
        });
    }

    // Payer search — filtered to property residents when a property is selected
    if (document.getElementById('payer_search')) {
        initSearch(
            'payer_search', 'payer_dropdown', 'paid_by',
            () => selectedPropertyId
                ? (residentsByProperty[selectedPropertyId] || [])
                : allPersons,
            p => p.full_name,
            p => p.person_id
        );
    }

    // Vehicle search (vehicle type)
    if (document.getElementById('vehicle_search')) {
        initSearch(
            'vehicle_search', 'vehicle_dropdown', 'vehicle_id',
            () => allVehicles,
            v => v.plate_number ? `${v.plate_number} (${v.make} ${v.model})` : `${v.make} ${v.model}`,
            v => v.vehicle_id
        );
    }
</script>
