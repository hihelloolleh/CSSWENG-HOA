<!-- ============================================================
     EMPLOYEES VIEW
     Layout: views/layouts/main.ejs (has sidebar & topbar)
     Controller: controllers/employeeController.js
     ============================================================ -->

<div class="main-wrapper">
    <div class="sidebar-open nav-item"> 
        <i class="fa-solid fa-bars"></i>
        <span>Open Sidebar</span>
    </div> 
    <header class="topbar">
        <div class="topbar-left">
            <h1 class="page-title">Dashboard</h1>
            <p class="page-subtitle">Welcome back, <strong>Admin</strong></p>
            <!-- TODO (SPRINT 2+): RENDER LIVE DATE/TIME FROM SERVER OR JS -->
            <p class="page-subtitle">June 16, 2026 08:00 PM PST</p>
        </div>
        <div class="topbar-right">
            <div class="topbar-user">
                <div class="user-avatar">
                    <i class="fa-solid fa-user"></i>
                </div>
                <div class="user-info">
                    <!-- TODO (SPRINT 2+): SHOW LOGGED-IN USER NAME AND ROLE -->
                    <span class="user-name">Village Admin</span>
                    <span class="user-role">Administrator</span>
                </div>
            </div>
        </div>
    </header>

    <main class="content">
        <div class="page-header">
            <h1>Employees</h1>
            <p>View, add, edit, and manage all employees</p>
        </div>

        <!-- ACTION BUTTONS -->
        <div class="action-buttons">
            <button class="btn btn-primary" onclick="openAddModal()">
                <i class="fa-solid fa-plus"></i> Add Employee
            </button>
        </div>

        <!-- DATA TABLE -->
        <div class="table-container">
            <table class="data-table">
                <thead>
                    <tr>
                        <th>Employee Name</th>
                        <th>Position</th>
                        <th>Email</th>
                        <th>Phone Number</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody id="tableBody">
                    <% if (employees.length === 0) { %>
                        <tr>
                            <td colspan="5" style="text-align: center; padding: 32px; color: #888;">
                                No employee records found. Click "Add Employee" to create one.
                            </td>
                        </tr>
                    <% } else { %>
                        <% employees.forEach(emp => { %>
                            <tr>
                                <td><strong><%= emp.first_name %> <%= emp.last_name %></strong></td>
                                <td><span class="badge position-badge"><%= emp.position %></span></td>
                                <td><%= emp.email || 'N/A' %></td>
                                <td><%= emp.contact_num || 'N/A' %></td>
                                <td>
                                    <!-- We pass database values right into our edit handler -->
                                    <button class="btn-action edit" 
                                            onclick="openEditModal('<%= emp.employee_id %>', '<%= emp.first_name %>', '<%= emp.last_name %>', '<%= emp.position %>', '<%= emp.salary %>', '<%= emp.email %>', '<%= emp.contact_num %>')">
                                        <i class="fa-solid fa-pen"></i>
                                    </button>
                                    <button class="btn-action delete" onclick="deleteEmployee('<%= emp.employee_id %>')">
                                        <i class="fa-solid fa-trash"></i>
                                    </button>
                                </td>
                            </tr>
                        <% }) %>
                    <% } %>
                </tbody>
            </table>
        </div>

        <!-- ADD / EDIT EMPLOYEE MODAL -->
        <div id="employeeModal" class="modal" style="display: none;">
            <div class="modal-content">
                <div class="modal-header">
                    <h2 id="modalTitle">Add New Employee</h2>
                    <button class="modal-close" onclick="closeModal()">&times;</button>
                </div>
                <div class="modal-body">
                    <form id="employeeForm" action="/employees" method="POST">
                        <input type="hidden" id="employeeId" name="employeeId">
                        
                        <div class="form-row" style="display: flex; gap: 16px; margin-bottom: 12px;">
                            <div class="form-group" style="flex: 1;">
                                <label>First Name *</label>
                                <input type="text" id="firstNameInput" name="first_name" required placeholder="Enter first name" style="width:100%;">
                            </div>
                            <div class="form-group" style="flex: 1;">
                                <label>Last Name *</label>
                                <input type="text" id="lastNameInput" name="last_name" required placeholder="Enter last name" style="width:100%;">
                            </div>
                        </div>
                        
                        <div class="form-row" style="display: flex; gap: 16px; margin-bottom: 12px;">
                            <div class="form-group" style="flex: 1;">
                                <label>Position *</label>
                                <select id="positionInput" name="position" required style="width:100%;">
                                    <option value="">Select Position</option>
                                    <option value="Security Guard">Security Guard</option>
                                    <option value="Maintenance">Maintenance</option>
                                    <option value="Bookeeper">Bookeeper</option>
                                    <option value="Secretary">Secretary</option>
                                    <option value="Others">Others</option>
                                </select>
                            </div>
                            <div class="form-group" style="flex: 1;">
                                <label>Salary (Monthly) *</label>
                                <input type="number" step="0.01" id="salaryInput" name="salary" required placeholder="0.00" style="width:100%;">
                            </div>
                        </div>
                        
                        <div class="form-group" style="margin-bottom: 12px;">
                            <label>Email Address</label>
                            <input type="email" id="emailInput" name="email" placeholder="Enter email address" style="width:100%;">
                        </div>
                        
                        <div class="form-group" style="margin-bottom: 16px;">
                            <label>Phone Number</label>
                            <input type="tel" id="phoneInput" name="contact_num" placeholder="Enter mobile number" style="width:100%;">
                        </div>
                        
                        <div class="modal-footer" style="text-align: right;">
                            <button type="button" class="btn btn-secondary" onclick="closeModal()">Cancel</button>
                            <button type="submit" class="btn btn-primary">Save Employee</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </main>
</div>
<script src="/js/sidebar.js"></script>
<!-- MODAL INTERACTION SCRIPTS -->
<script>
    const modal = document.getElementById('employeeModal');
    const form = document.getElementById('employeeForm');
    const modalTitle = document.getElementById('modalTitle');

    function openAddModal() {
        modalTitle.innerText = "Add New Employee";
        form.action = "/employees"; // POST endpoint for record insertion
        form.reset();
        document.getElementById('employeeId').value = "";
        modal.style.display = 'block';
    }

    function openEditModal(id, firstName, lastName, position, salary, email, contactNum) {
        modalTitle.innerText = "Edit Employee Details";
        form.action = "/employees/update"; // Submission route for updates
        
        // Inject selected row values directly into form fields
        document.getElementById('employeeId').value = id;
        document.getElementById('firstNameInput').value = firstName;
        document.getElementById('lastNameInput').value = lastName;
        document.getElementById('positionInput').value = position;
        document.getElementById('salaryInput').value = salary;
        document.getElementById('emailInput').value = (email === 'N/A') ? '' : email;
        document.getElementById('phoneInput').value = (contactNum === 'N/A') ? '' : contactNum;
        
        modal.style.display = 'block';
    }

    function closeModal() {
        modal.style.display = 'none';
    }

    async function deleteEmployee(id) {
        if(confirm("Are you sure you want to delete this employee?")) {
            const res = await fetch(`/employees/${id}`, { method: 'DELETE' });
            if(res.ok) window.location.reload();
        }
    }
</script>
