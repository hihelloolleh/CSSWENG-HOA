<!-- ============================================================
     EMPLOYEES VIEW
     Layout: views/layouts/main.ejs (has sidebar & topbar)
     Controller: controllers/employeeController.js
     ============================================================ -->

<div class="main-wrapper">
    <div class="sidebar-open nav-item"> 
        <i class="fa-solid fa-bars"></i>
        <span>Open Sidebar</span>
    </div> 
    <header class="topbar">
        <div class="topbar-left">
            <h1 class="page-title">Employees</h1>
            <p class="page-subtitle">View, add, edit, and manage all employees</p>

        </div>
        <div class="topbar-right">
            <div class="topbar-user">
                <div class="user-avatar">
                    <i class="fa-solid fa-user"></i>
                </div>
                <div class="user-info">
                    <!-- TODO (SPRINT 2+): SHOW LOGGED-IN USER NAME AND ROLE -->
                    <span class="user-name">Village Admin</span>
                    <span class="user-role">Administrator</span>
                </div>
            </div>
        </div>
    </header>

    <main class="content">
        <!-- ACTION BUTTONS -->
        <div class="action-buttons">
            <button class="btn btn-primary" onclick="openAddModal()">
                <i class="fa-solid fa-plus"></i> Add Employee
            </button>
        </div>

        <!-- DATA TABLE -->
        <div class="table-container">
            <table class="data-table">
                <thead>
                    <tr>
                        <th>Employee Name</th>
                        <th>Position</th>
                        <th>Email</th>
                        <th>Phone Number</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody id="tableBody">
                    <% if (employees.length === 0) { %>
                        <tr>
                            <td>
                                No employee records found. Click "Add Employee" to create one.
                            </td>
                        </tr>
                    <% } else { %>
                        <% employees.forEach(emp => { %>
                            <tr>
                                <td><strong><%= emp.first_name %> <%= emp.middle_name %> <%= emp.last_name %> <%= emp.suffix %></strong></td>
                                <td><span class="badge position-badge"><%= emp.position %></span></td>
                                <td><%= emp.email || 'N/A' %></td>
                                <td><%= emp.contact_num || 'N/A' %></td>
                                <td>
                                    <!-- We pass database values right into our edit handler -->
                                    <button class="btn-action edit" 
                                            onclick="openEditModal('<%= emp.employee_id %>', '<%= emp.first_name %>', '<%= emp.last_name %>', '<%= emp.position %>', '<%= emp.salary %>', '<%= emp.email %>', '<%= emp.contact_num %>')">
                                        <i class="fa-solid fa-pen"></i>
                                    </button>
                                    <button class="btn-action delete" onclick="deleteEmployee('<%= emp.employee_id %>')">
                                        <i class="fa-solid fa-trash"></i>
                                    </button>
                                </td>
                            </tr>
                        <% }) %>
                    <% } %>
                </tbody>
            </table>
        </div>

        <!-- ADD / EDIT EMPLOYEE MODAL -->
        <div id="employeeModal" class="modal">
            <div class="modal-content">

                <div class="modal-header">
                    <h2 id="modalTitle">Add New Employee</h2>
                    <button class="modal-close" onclick="closeModal()">&times;</button>
                </div>

                <div class="modal-body">
                    <form id="employeeForm" action="/employees" method="POST">

                        <input type="hidden" id="employeeId" name="employeeId">

                        <!-- NAME ROW 1 -->
                        <div class="form-row">
                            <div class="form-group">
                                <label>First Name *</label>
                                <input type="text" id="firstNameInput" name="first_name" required>
                            </div>

                            <div class="form-group">
                                <label>Middle Name</label>
                                <input type="text" id="middleNameInput" name="middle_name">
                            </div>
                        </div>

                        <!-- NAME ROW 2 -->
                        <div class="form-row">
                            <div class="form-group">
                                <label>Last Name *</label>
                                <input type="text" id="lastNameInput" name="last_name" required>
                            </div>

                            <div class="form-group">
                                <label>Suffix</label>
                                <input type="text" id="suffixInput" name="suffix">
                            </div>
                        </div>

                        <!-- POSITION + SALARY -->
                        <div class="form-row">
                            <div class="form-group">
                                <label>Position *</label>
                                <select id="positionInput" name="position" required>
                                    <option value="">Select Position</option>
                                    <option value="Security Guard">Security Guard</option>
                                    <option value="Maintenance">Maintenance</option>
                                    <option value="Bookkeeper">Bookkeeper</option>
                                    <option value="Secretary">Secretary</option>
                                    <option value="Others">Others</option>
                                </select>
                            </div>

                            <div class="form-group">
                                <label>Salary *</label>
                                <input type="number" id="salaryInput" name="salary" required>
                            </div>
                        </div>

                        <!-- CONTACT -->
                        <div class="form-group">
                            <label>Email</label>
                            <input type="email" id="emailInput" name="email">
                        </div>

                        <div class="form-group">
                            <label>Phone</label>
                            <input type="tel" id="phoneInput" name="contact_num">
                        </div>

                        <!-- BUTTONS -->
                        <div class="modal-footer">
                            <button type="button" onclick="closeModal()">Cancel</button>
                            <button type="submit">Save Employee</button>
                        </div>

                    </form>
                </div>

            </div>
        </div>
    </main>
</div>
<script src="/js/sidebar.js"></script>
<!-- MODAL INTERACTION SCRIPTS -->
<script>
    const modal = document.getElementById('employeeModal');
    const form = document.getElementById('employeeForm');
    const modalTitle = document.getElementById('modalTitle');

    function openAddModal() {
        modalTitle.innerText = "Add New Employee";
        form.action = "/employees"; // POST endpoint for record insertion
        form.reset();
        document.getElementById('employeeId').value = "";
        modal.classList.add("active");
    }

    function openEditModal(emp) {
        modalTitle.innerText = "Edit Employee Details";
        form.action = "/employees/update";

        document.getElementById('employeeId').value = emp.employee_id;

        document.getElementById('firstNameInput').value = emp.first_name || '';
        document.getElementById('middleNameInput').value = emp.middle_name || '';
        document.getElementById('lastNameInput').value = emp.last_name || '';
        document.getElementById('suffixInput').value = emp.suffix || '';

        document.getElementById('positionInput').value = emp.position || '';
        document.getElementById('salaryInput').value = emp.salary || '';

        document.getElementById('emailInput').value = emp.email || '';
        document.getElementById('phoneInput').value = emp.contact_num || '';

        modal.classList.add("active");
    }

    function closeModal() {
        modal.classList.remove("active");
    }

    async function deleteEmployee(id) {
        if(confirm("Are you sure you want to delete this employee?")) {
            const res = await fetch(`/employees/${id}`, { method: 'DELETE' });
            if(res.ok) window.location.reload();
        }
    }
</script>
