<div class="main-wrapper">
    <div class="sidebar-open nav-item">
        <i class="fa-solid fa-bars"></i>
        <span>Open Sidebar</span>
    </div>

    <header class="topbar">
        <div class="topbar-left">
            <h1 class="page-title">Payment Ledger</h1>
            <p class="page-subtitle">View, add, edit, and manage all transactions</p>
        </div>
        <div class="topbar-right">
            <div class="topbar-user">
                <div class="user-avatar"><i class="fa-solid fa-user"></i></div>
                <div class="user-info">
                    <span class="user-name">Village Admin</span>
                    <span class="user-role">Administrator</span>
                </div>
            </div>
        </div>
    </header>

    <main class="content">
        <!-- TODO: OUTSTANDING BALANCE VISIBLE HERE AND VISIBLE ON PROPERTIES TAB -->
         
        <% if (success) { %>
            <div class="alert alert-success"><i class="fa-solid fa-circle-check"></i> <%= success %></div>
        <% } %>
        <% if (error) { %>
            <div class="alert alert-error"><i class="fa-solid fa-circle-exclamation"></i> <%= error %></div>
        <% } %>

        <!-- ACTION BAR -->
        <div class="action-bar">
            <div style="display:flex; gap:12px; align-items:center; flex-wrap:wrap;">
                <input type="text" class="search-input" id="searchInput"
                       placeholder="Search transactions..."
                       oninput="filterTable()">

                <!-- PURPOSE FILTER -->
                 <!-- TODO: CHANGE PURPOSE FILTER INTO BUTTONS ON TOP, BASICALLY ANOTHER (SIDEBAR) -->
                <form id="purposeFilterForm" method="GET" action="/payments" style="display:flex; gap:8px; align-items:center;">
                    <select name="purpose" class="form-control" style="width:auto;"
                            onchange="document.getElementById('purposeFilterForm').submit()">
                        <option value="">All Purposes</option>
                        <% const purposes = ['Vehicle Sticker','Association Dues','Outstanding Balance','General Payments']; %>
                        <% purposes.forEach(p => { %>
                            <option value="<%= p %>" <%= filterPurpose === p ? 'selected' : '' %>><%= p %></option>
                        <% }) %>
                    </select>
                </form>
            </div>

            <div>
                <button class="btn btn-primary" id="openModal">
                    <i class="fa-solid fa-plus"></i> Add Payment
                </button>
            </div>
        </div>

        <!-- PAYMENT COUNTER -->
        <p class="payment-count" id="paymentCount">
            Showing <strong id="visibleCount"><%= payments.length %></strong> payment<%= payments.length !== 1 ? 's' : '' %>
            <% if (filterPurpose) { %> &mdash; filtered by <em><%= filterPurpose %></em><% } %>
        </p>

        <!-- DATA TABLE -->
        <div class="table-container">
            <table class="data-table" id="paymentTable">
                <thead>
                    <tr>
                        <th>Date Paid</th>
                        <th>Payer</th>
                        <th>Purpose</th>
                        <th>Expected</th>
                        <th>Paid</th>
                        <th>Method</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (payments.length === 0) { %>
                        <tr>
                            <td colspan="8" class="empty-state">
                                No payment records found. Click "Add Payment" to create one.
                            </td>
                        </tr>
                    <% } else { %>
                        <% payments.forEach(function(pay) {
                            let status = 'Unpaid';
                            let statusClass = 'status-unpaid';
                            if (parseFloat(pay.amount_paid) > 0) {
                                if (parseFloat(pay.amount_paid) >= parseFloat(pay.amount_expected)) {
                                    status = 'Paid';
                                    statusClass = 'status-paid';
                                } else {
                                    status = 'Partial';
                                    statusClass = 'status-partial';
                                }
                            }
                            const datePaid = pay.date_paid
                                ? new Date(pay.date_paid).toLocaleDateString('en-PH', { year:'numeric', month:'short', day:'numeric' })
                                : '—';
                        %>
                        <tr>
                            <td><%= datePaid %></td>
                            <td><%= pay.payer_name || '—' %></td>
                            <td><span class="purpose-badge"><%= pay.purpose %></span></td>
                            <td>&#8369; <%= parseFloat(pay.amount_expected).toLocaleString('en-PH', {minimumFractionDigits:2}) %></td>
                            <td>&#8369; <%= parseFloat(pay.amount_paid).toLocaleString('en-PH', {minimumFractionDigits:2}) %></td>
                            <td><%= pay.payment_method %></td>
                            <td><span class="payment-status <%= statusClass %>"><%= status %></span></td>
                            <td style="display:flex; gap:6px; align-items:center;">
                                <button class="btn-icon"
                                        title="View Details"
                                        onclick="openViewModal(this)"
                                        data-id="<%= pay.payment_id %>"
                                        data-payer="<%= pay.payer_name || '' %>"
                                        data-purpose="<%= pay.purpose %>"
                                        data-expected="<%= pay.amount_expected %>"
                                        data-paid="<%= pay.amount_paid %>"
                                        data-date="<%= pay.date_paid || '' %>"
                                        data-method="<%= pay.payment_method %>"
                                        data-receipt="<%= pay.receipt_number || '' %>"
                                        data-remarks="<%= pay.remarks || '' %>">
                                    <i class="fa-solid fa-eye"></i>
                                </button>
                                <button class="btn-icon"
                                        title="Edit"
                                        onclick="openEditModal(this)"
                                        data-id="<%= pay.payment_id %>"
                                        data-purpose="<%= pay.purpose %>"
                                        data-expected="<%= pay.amount_expected %>"
                                        data-paid="<%= pay.amount_paid %>"
                                        data-date="<%= pay.date_paid || '' %>"
                                        data-method="<%= pay.payment_method %>"
                                        data-receipt="<%= pay.receipt_number || '' %>"
                                        data-remarks="<%= pay.remarks || '' %>"
                                        data-paidby="<%= pay.paid_by || '' %>">
                                    <i class="fa-solid fa-pen"></i>
                                </button>
                                <button class="btn-icon btn-icon-danger"
                                        title="Delete"
                                        onclick="confirmDelete(this.dataset.id, this.dataset.label)"
                                        data-id="<%= pay.payment_id %>"
                                        data-label="<%= pay.payer_name || pay.purpose %>">
                                    <i class="fa-solid fa-trash"></i>
                                </button>
                            </td>
                        </tr>
                        <% }) %>
                    <% } %>
                </tbody>
            </table>
        </div>
    </main>
</div>

<div class="modal" id="modal">
    <div class="modal-content">
        <div class="modal-header"> 
            <h2>Create Payment</h2>
        </div>

        <div class="modal-body">
            <form>
                <div class="form-group">
                    <label>Payment Purpose</label>
                    <select id="purpose">
                        <option value="">Choose...</option>
                        <option value="association">Association Dues</option>
                        <option value="vehicle">Vehicle Sticker</option>
                        <option value="outstanding">Outstanding Balance</option>
                        <option value="general">General Payments</option>
                    </select>
                </div>
                
            </form>
            
        </div>

        <div class="modal-footer">
            <button class="cancel btn btn-secondary"> Cancel </button>
            <button class="btn btn-primary" id="continue"> Continue </button>   
        </div>
    </div>
</div>

<script id="personData" type="application/json"><%- JSON.stringify(persons) %></script>
<script src="/js/paymentLedger.js"></script>
<script src="/js/sidebar.js"></script>
 
