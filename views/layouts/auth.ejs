<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= typeof title !== 'undefined' ? title : 'HOA' %></title>

    <!-- PAGE-SPECIFIC CSS — set by the route in index.js -->
    <% if (typeof pageCSS !== 'undefined') { %>
        <link rel="stylesheet" href="/css/<%= pageCSS %>">
    <% } %>

    <!-- GOOGLE FONTS -->
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet">
</head>
<body>

    <!-- NO SIDEBAR ON AUTH PAGES -->
    <%- body %>

</body>
</html>
