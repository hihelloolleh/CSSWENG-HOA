<header class="topbar">
    <div class="topbar-left">
        <h1 class="page-title">Residents Management</h1>
        <p class="page-subtitle">Manage all village residents</p>
    </div>
    <div class="topbar-right">
        <div class="topbar-user">
            <div class="user-avatar"><i class="fa-solid fa-user"></i></div>
            <div class="user-info">
                <span class="user-name">HOA Admin</span>
                <span class="user-role">Administrator</span>
            </div>
        </div>
    </div>
</header>

<main class="content">
    <section class="tables-row" style="grid-template-columns: 1fr;">
        <div class="card table-card">
            <div class="card-header">
                <h2>All Residents</h2>
                <!-- TODO (SPRINT 2+): WIRE THIS BUTTON TO OPEN ADD PERSON FORM -->
                <button id="add-person-btn" style="padding: 8px 16px; background-color: #526F50; color: white; border: none; border-radius: 6px; cursor: pointer; font-family: inherit;">
                    <i class="fa-solid fa-plus"></i> Add a New Resident
                </button>
            </div>

            <table class="data-table">
                <thead>
                    <tr>
                        <th>Resident ID</th>
                        <th>Name</th>
                        <th>Address</th>
                        <th>Contact Details</th>
                        <th>Other Info</th>
                    </tr>
                </thead>
                <tbody id="resident-table-body">
                    <!-- TODO (SPRINT 2+): LOOP THROUGH persons ARRAY FROM DB -->
                    <!-- <% persons.forEach(p => { %> -->
                    <!-- <tr> -->
                    <!--   <td><%= p.person_id %></td> -->
                    <!--   <td><%= p.first_name %> <%= p.last_name %></td> -->
                    <!--   <td>...</td> -->
                    <!--   <td><%= p.contact_number %></td> -->
                    <!--   <td><%= p.sex %> | <%= p.birth_date %></td> -->
                    <!-- </tr> -->
                    <!-- <% }) %> -->
                    <tr>
                        <td colspan="5" style="text-align:center; color:#888; padding: 32px;">
                            No residents yet. Connect the database in Sprint 2.
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </section>

    <!-- TODO (SPRINT 2+): REPLACE WITH ACTUAL MODAL COMPONENT -->
    <div id="person-modal" style="display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.5); justify-content: center; align-items: center; z-index: 1000;">
        <div class="card" style="width: 400px; padding: 20px;">
            <h2 id="modal-title">Add New Resident</h2>
        </div>
    </div>
</main>
