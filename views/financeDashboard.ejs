<!-- ============================================================
     DASHBOARD VIEW
     Layout: views/layouts/main.ejs (has sidebar)
     Controller: controllers/dashboardController.js
   
     ============================================================ -->

<div class="main-wrapper"> 
    <div class="sidebar-open nav-item"> 
        <i class="fa-solid fa-bars"></i>
        <span>Open Sidebar</span>
    </div>

    <header class="topbar">
        <div class="topbar-left"> 
            <h1 class="page-title">Finance Dashboard</h1>
            <p class="page-subtitle">Welcome back, <strong>Admin</strong></p>
            <!-- TODO (SPRINT 2+): RENDER LIVE DATE/TIME FROM SERVER OR JS -->
            <p class="page-subtitle">June 16, 2026 08:00 PM PST</p>
        </div>
        <div class="topbar-right">
            <div class="topbar-user">
                <div class="user-avatar">
                    <i class="fa-solid fa-user"></i>
                </div>
                <div class="user-info">
                    <!-- TODO (SPRINT 2+): SHOW LOGGED-IN USER NAME AND ROLE -->
                    <span class="user-name">Village Admin</span>
                    <span class="user-role">Administrator</span>
                </div>
            </div>
        </div>
    </header>

    <main class="content">

        <!-- SUMMARY STAT CARDS -->
        <section class="summary-cards row2">
            <div class="card stat-card">
                <div class="stat-icon green">
                    <i class="fa-solid fa-money-bill-trend-up"></i>
                </div>
                <div class="stat-info">
                    <span class="stat-value">1.5 M</span>
                    <span class="stat-label">Total Revenue</span>
                </div>
            </div>

            <div class="card stat-card">
                <div class="stat-icon yellow">
                    <i class="fa-solid fa-hand-holding-dollar"></i>
                </div>
                <div class="stat-info">
                    <span class="stat-value">45 K</span>
                    <span class="stat-label">Total Collectibles</span>
                </div>
            </div>

            <div class="card stat-card">
                <div class="stat-icon red">
                    <i class="fa-solid fa-money-bill-transfer"></i>
                </div>
                <div class="stat-info">
                    <span class="stat-value">120 K</span>
                    <span class="stat-label">Total Expenses</span>
                </div>
            </div>
        </section>
    </main>
</div>

<script src="/js/sidebar.js"></script>
