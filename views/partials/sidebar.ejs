<%
// activePage is passed by every controller.
// Values: 'dashboard' | 'residents' | 'boardMembers' | 'properties'
//         | 'employees' | 'vehicles'
const page = typeof activePage !== 'undefined' ? activePage : '';
%>

<aside class="sidebar">
    <div class="sidebar-logo">
        <div class="sidebar-close nav-item">
            <i class="fa-solid fa-times"></i>
        </div> 
        <img src="/images/HOA LOGO.png" alt="HOA Logo">
        <div class="sidebar-logo-text">
            <span class="logo-title">Marcelo Green Village</span>
            <span class="logo-sub">Phase 5</span>
        </div>
          
    </div>

    <nav class="sidebar-nav">
        <a href="/dashboard" class="nav-item <%= page === 'dashboard' ? 'active' : '' %>">
            <i class="fa-solid fa-gauge-high"></i>
            <span>Dashboard</span>
        </a>
        <a href="/residents" class="nav-item <%= page === 'residents' ? 'active' : '' %>">
            <i class="fa-solid fa-people-roof"></i>
            <span>Residents</span>
        </a>
        <a href="/properties" class="nav-item <%= page === 'properties' ? 'active' : '' %>">
            <i class="fa-solid fa-house"></i>
            <span>Properties</span>
        </a>
        
        <a href="/employees" class="nav-item <%= page === 'employees' ? 'active' : '' %>">
            <i class="fa-solid fa-id-badge"></i>
            <span>Employees</span>
        </a>
        <a href="/vehicles" class="nav-item <%= page === 'vehicles' ? 'active' : '' %>">
            <i class="fa-solid fa-car"></i>
            <span>Vehicles</span>
        </a>
    </nav>

    <div class="sidebar-footer">
        <a href="/login" class="nav-item logout">
            <i class="fa-solid fa-right-from-bracket"></i>
            <span>Log Out</span>
        </a>
    </div>
</aside>

 
