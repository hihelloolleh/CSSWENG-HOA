<%
// activePage is passed by every controller.
// Values: 'dashboard' | 'residents' | 'boardMembers' | 'properties'
//         | 'employees' | 'vehicles' | 'rates'
const page = typeof activePage !== 'undefined' ? activePage : '';
const financePages = ['financeDashboard', 'paymentLedger', 'payments', 'rates'];
const financeOpen = financePages.includes(page);
%>

<aside class="sidebar">
    <div class="sidebar-logo">
        <div class="sidebar-close nav-item">
            <i class="fa-solid fa-times"></i>
        </div> 
        <img src="/images/HOA LOGO.png" alt="HOA Logo">
        <div class="sidebar-logo-text">
            <span class="logo-title">Marcelo Green Village</span>
            <span class="logo-sub">Phase 5</span>
        </div>
          
    </div>

    <nav class="sidebar-nav">
        <a href="/dashboard" class="nav-item <%= page === 'dashboard' ? 'active' : '' %>">
            <i class="fa-solid fa-gauge-high"></i>
            <span>Dashboard</span>
        </a>
        <a href="/residents" class="nav-item <%= page === 'residents' ? 'active' : '' %>">
            <i class="fa-solid fa-people-roof"></i>
            <span>Residents & Board Members</span>
        </a>
        <a href="/properties" class="nav-item <%= page === 'properties' ? 'active' : '' %>">
            <i class="fa-solid fa-house"></i>
            <span>Properties</span>
        </a>
        
        <a href="/employees" class="nav-item <%= page === 'employees' ? 'active' : '' %>">
            <i class="fa-solid fa-id-badge"></i>
            <span>Employees</span>
        </a>
        <a href="/vehicles" class="nav-item <%= page === 'vehicles' ? 'active' : '' %>">
            <i class="fa-solid fa-car"></i>
            <span>Vehicles</span>
        </a>
        <div class="main-tab <%= financeOpen ? 'open' : '' %>">
            <div class="nav-item finance-toggle">
                <i class="fa-solid fa-building-columns"></i>
                <span>Finance</span>
                <i class="fa-solid fa-angle-down finance-arrow"></i>
            </div>

            <div class="sub-tab <%= financeOpen ? 'show' : '' %>">
                <a href="/finances" class="nav-item <%= page === 'financeDashboard' ? 'active' : '' %>">
                    <i class="fa-solid fa-chart-line"></i>
                    <span>Finance Dashboard</span>
                </a>

                <a href="/payments" class="nav-item <%= page === 'paymentLedger' ? 'active' : '' %>">
                    <i class="fa-solid fa-file-invoice"></i>
                    <span>Payment Ledger</span>
                </a>

                <a href="/rates" class="nav-item <%= page === 'rates' ? 'active' : '' %>">
                    <i class="fas fa-dollar-sign"></i>
                    <span>Rates</span>
                </a>
            </div>
        </div>
        
    </nav>

    <div class="sidebar-footer">
        <a href="/login" class="nav-item logout">
            <i class="fa-solid fa-right-from-bracket"></i>
            <span>Log Out</span>
        </a>
    </div>
</aside>

 
