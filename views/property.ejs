<!-- ============================================================
     PROPERTY VIEW — Full CRUD
     Layout : views/layouts/main.ejs
     Controller: controllers/propertyController.js
     Model : models/propertyModel.js
     ============================================================ -->

<header class="topbar">
    <div class="topbar-left">
        <h1 class="page-title">Properties</h1>
        <p class="page-subtitle">View, edit, and manage properties.</p>
    </div>
    <div class="topbar-right">
        <div class="topbar-user">
            <div class="user-avatar"><i class="fa-solid fa-user"></i></div>
            <div class="user-info">
                <span class="user-name">Village Admin</span>
                <span class="user-role">Administrator</span>
            </div>
        </div>
    </div>
</header>

<main class="content">

    <!-- Flash messages -->
    <% if (success) { %>
        <div class="alert alert-success"><i class="fa-solid fa-circle-check"></i> <%= success %></div>
    <% } %>
    <% if (error) { %>
        <div class="alert alert-error"><i class="fa-solid fa-circle-exclamation"></i> <%= error %></div>
    <% } %>

    <!-- Toolbar -->
    <div class="toolbar">
        <button class="btn btn-primary" onclick="openAddModal()">
            <i class="fa-solid fa-plus"></i> Add Property
        </button>
        <div class="search-bar">
            <input type="text" class="search-input" id="searchInput"
                   placeholder="Search by street name, type, or owner..."
                   oninput="filterTable()">
        </div>
    </div>

    <!-- Table -->
    <div class="table-container">
        <table class="data-table" id="propertyTable">
            <thead>
                <tr>
                    <th>Street Name</th>
                    <th>Property Type</th>
                    <th>Homeowner</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                <% if (properties.length === 0) { %>
                <tr>
                    <td colspan="4" style="text-align:center; color:#888; padding:40px;">
                        No properties found. Add one to get started.
                    </td>
                </tr>
                <% } %>
                <% properties.forEach(p => { %>
                <tr>
                    <td><%= p.street_name %></td>
                    <td><%= p.property_type %></td>
                    <td><%= p.owner_name || '—' %></td>
                    <td>
                        <button class="btn-icon"
                            onclick="openEditModal(
                                <%= p.property_id %>,
                                '<%= p.property_type.replace(/'/g, "\\'") %>',
                                '<%= p.street_name.replace(/'/g, "\\'") %>',
                                <%= p.owner_resident_id || 'null' %>
                            )">
                            <i class="fa-solid fa-pen-to-square"></i>
                        </button>
                        <button class="btn-icon btn-icon-danger"
                            onclick="confirmDelete(<%= p.property_id %>, '<%= p.street_name.replace(/'/g, "\\'") %>')">
                            <i class="fa-solid fa-trash"></i>
                        </button>
                    </td>
                </tr>
                <% }) %>
            </tbody>
        </table>
    </div>
</main>

<!-- ── ADD / EDIT MODAL ─────────────────────────────────────────────────── -->
<div id="propertyModal" class="modal-overlay" style="display:none;">
    <div class="modal">
        <div class="modal-header">
            <h2 id="modalTitle">Add Property</h2>
            <button class="modal-close" onclick="closeModal('propertyModal')">
                <i class="fa-solid fa-xmark"></i>
            </button>
        </div>

        <form id="propertyForm" method="POST" action="/properties">
            <div class="modal-body">
                <div class="form-group">
                    <label for="street_name">Street Name / Address</label>
                    <input type="text" id="street_name" name="street_name"
                           class="form-control" placeholder="e.g. 12 Sampaguita St." required>
                </div>

                <div class="form-group">
                    <label for="property_type">Property Type</label>
                    <select id="property_type" name="property_type" class="form-control" required>
                        <option value="">-- Select type --</option>
                        <option value="House">House</option>
                        <option value="Others">Others</option>
                    </select>
                </div>

                <div class="form-group">
                    <label for="owner_resident_id">Homeowner (optional)</label>
                    <select id="owner_resident_id" name="owner_resident_id" class="form-control">
                        <option value="">-- No homeowner assigned --</option>
                        <% residents.forEach(r => { %>
                        <option value="<%= r.resident_id %>"><%= r.full_name %></option>
                        <% }) %>
                    </select>
                </div>
            </div>

            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" onclick="closeModal('propertyModal')">
                    Cancel
                </button>
                <button type="submit" class="btn btn-primary" id="submitBtn">
                    Add Property
                </button>
            </div>
        </form>
    </div>
</div>

<!-- ── DELETE CONFIRMATION MODAL ────────────────────────────────────────── -->
<div id="deleteModal" class="modal-overlay" style="display:none;">
    <div class="modal modal-sm">
        <div class="modal-header">
            <h2>Delete Property</h2>
            <button class="modal-close" onclick="closeModal('deleteModal')">
                <i class="fa-solid fa-xmark"></i>
            </button>
        </div>
        <div class="modal-body">
            <p>Are you sure you want to delete <strong id="deletePropertyName"></strong>?
               This cannot be undone.</p>
        </div>
        <div class="modal-footer">
            <button class="btn btn-secondary" onclick="closeModal('deleteModal')">Cancel</button>
            <form id="deleteForm" method="POST">
                <button type="submit" class="btn btn-danger">Delete</button>
            </form>
        </div>
    </div>
</div>

<script>
    // ── Modal helpers ────────────────────────────────────────────────────────
    function openAddModal() {
        document.getElementById('modalTitle').textContent  = 'Add Property';
        document.getElementById('submitBtn').textContent   = 'Add Property';
        document.getElementById('propertyForm').action     = '/properties';
        document.getElementById('street_name').value       = '';
        document.getElementById('property_type').value     = '';
        document.getElementById('owner_resident_id').value = '';
        document.getElementById('propertyModal').style.display = 'flex';
    }

    function openEditModal(id, type, street, ownerResidentId) {
        document.getElementById('modalTitle').textContent  = 'Edit Property';
        document.getElementById('submitBtn').textContent   = 'Save Changes';
        document.getElementById('propertyForm').action     = '/properties/' + id + '/update';
        document.getElementById('street_name').value       = street;
        document.getElementById('property_type').value     = type;
        document.getElementById('owner_resident_id').value = ownerResidentId || '';
        document.getElementById('propertyModal').style.display = 'flex';
    }

    function confirmDelete(id, streetName) {
        document.getElementById('deletePropertyName').textContent = streetName;
        document.getElementById('deleteForm').action = '/properties/' + id + '/delete';
        document.getElementById('deleteModal').style.display = 'flex';
    }

    function closeModal(id) {
        document.getElementById(id).style.display = 'none';
    }

    // Close on backdrop click
    document.querySelectorAll('.modal-overlay').forEach(overlay => {
        overlay.addEventListener('click', function(e) {
            if (e.target === this) closeModal(this.id);
        });
    });

    // ── Search filter ────────────────────────────────────────────────────────
    function filterTable() {
        const q = document.getElementById('searchInput').value.toLowerCase();
        document.querySelectorAll('#propertyTable tbody tr').forEach(row => {
            row.style.display = row.textContent.toLowerCase().includes(q) ? '' : 'none';
        });
    }

    // ── Auto-dismiss alerts ──────────────────────────────────────────────────
    setTimeout(() => {
        document.querySelectorAll('.alert').forEach(a => a.style.display = 'none');
    }, 4000);
</script>
